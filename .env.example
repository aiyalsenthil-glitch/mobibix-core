# MobiBix Core: Official Environment Template

# 1. Database Connection
DATABASE_URL=postgresql://mobibix:mobibix_password@localhost:5432/mobibix_db

# 2. Authentication Mode (local | firebase)
# Use 'local' for full sovereignty.
AUTH_MODE=local

# 3. Cloud Integration Layer (for AI, WhatsApp, Premium Analytics)
# Default MobiBix Cloud API endpoint.
MB_CLOUD_URL=https://api.mobibix.in/v1

# Your Cloud API Key (Get yours at mobibix.in)
# Leave empty for strictly local development.
MB_API_KEY=

# Enable anonymous telemetry for system health (true | false)
MB_TELEMETRY_ENABLED=true

# 4. Infrastructure
PORT=3000
REDIS_URL=redis://localhost:6379