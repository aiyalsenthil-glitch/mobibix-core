{
  "moduleFileExtensions": ["js", "json", "ts", "tsx"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".(e2e-spec|e2e.spec|spec).ts$",
  "transform": {
    "^.+\\.(t|j)sx?$": ["ts-jest", {
      "tsconfig": "<rootDir>/../tsconfig.json"
    }]
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1",
    "^src/(.*)$": "<rootDir>/../src/$1"
  },
  "setupFiles": ["<rootDir>/jest.setup.env.js"]
}
