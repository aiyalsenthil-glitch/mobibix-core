enum ProductType {
  GOODS
  SPARE
  SERVICE
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String                 @id @default(cuid())
  name             String
  legalName        String?
  tenantType       String
  code             String                 @unique
  contactPhone     String?
  contactEmail     String?
  website          String?
  logoUrl          String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  pincode          String?
  country          String                 @default("India")
  gstNumber        String?
  taxId            String?
  businessType     String?
  currency         String                 @default("INR")
  timezone         String                 @default("Asia/Kolkata")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  kioskToken       String?                @unique
  maxMembers       Int                    @default(50)
  whatsappEnabled  Boolean                @default(true)
  auditLogs        AuditLog[]
  members          Member[]
  payments         Payment[]
  subscription     TenantSubscription[]
  users            User[]
  userTenants      UserTenant[]
  shops            Shop[]
  shopStaffs       ShopStaff[]
  jobCards         JobCard[]
  shopProducts     ShopProduct[]
  stockEntries     StockLedger[]
  invoices         Invoice[]
  financialEntries FinancialEntry[]
  ledgerCustomers  LedgerCustomer[]
  ledgerAccounts   LedgerAccount[]
  customers        Customer[]
  imeis            IMEI[]
  suppliers        Supplier[]
  globalSuppliers  TenantGlobalSupplier[]
  purchases        Purchase[]
  receipts         Receipt[]
  paymentVouchers  PaymentVoucher[]
  quotations       Quotation[]
  purchaseOrders   PurchaseOrder[]
  tenantProducts   TenantProduct[]
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model User {
  id               String       @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid      String       @unique
  email            String?
  fullName         String?
  avatar           String?
  role             UserRole
  tenantId         String?
  permissions      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  phone            String?
  welcomeEmailSent Boolean      @default(false)
  auditLogs        AuditLog[]
  tenant           Tenant?      @relation(fields: [tenantId], references: [id])
  userTenants      UserTenant[]
  shopStaffs       ShopStaff[]
}

model Member {
  id                  String              @id @default(uuid())
  tenantId            String
  fullName            String
  phone               String
  gender              Gender
  membershipPlanId    String
  membershipStartAt   DateTime
  membershipEndAt     DateTime
  feeAmount           Int
  paymentStatus       MemberPaymentStatus
  heightCm            Float
  weightKg            Float
  fitnessGoal         FitnessGoal
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  paidAmount          Int                 @default(0)
  monthlyFee          Int
  paymentDueDate      DateTime
  paymentReminderSent Boolean             @default(false)
  isActive            Boolean             @default(true)
  photoUrl            String?
  welcomeMessageSent  Boolean             @default(false)
  attendances         GymAttendance[]
  gymMemberships      GymMembership[]
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  payments            MemberPayment[]

  @@unique([id, tenantId])
  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Customer {
  id       String @id @default(cuid())
  tenantId String

  name  String
  phone String
  email String?

  state     String
  gstNumber String?

  businessType BusinessType @default(B2C)
  partyType    PartyType    @default(CUSTOMER)

  loyaltyPoints Int     @default(0)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]
  jobCards JobCard[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model LedgerCustomer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  ledgers LedgerAccount[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model LedgerAccount {
  id         String @id @default(cuid())
  tenantId   String
  customerId String

  principalAmount   Int
  expectedTotal     Int
  installmentType   LedgerInstallmentType
  installmentAmount Int
  totalPeriods      Int

  startDate DateTime
  status    LedgerStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  customer LedgerCustomer @relation(fields: [customerId], references: [id])

  collections LedgerCollection[]

  @@index([tenantId])
  @@index([customerId])
}

model LedgerCollection {
  id       String @id @default(cuid())
  tenantId String
  ledgerId String

  periodNo Int
  dueDate  DateTime
  amount   Int
  paid     Boolean   @default(false)
  paidAt   DateTime?

  createdAt DateTime @default(now())

  ledger LedgerAccount @relation(fields: [ledgerId], references: [id])

  @@index([tenantId])
  @@index([ledgerId])
}

model StaffInvite {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  createdAt DateTime @default(now())
  accepted  Boolean  @default(false)
  role      UserRole @default(STAFF)
  name      String?
  phone     String?

  @@unique([tenantId, email])
}

model MemberPayment {
  id           String              @id @default(cuid())
  tenantId     String
  memberId     String
  amount       Int
  status       MemberPaymentStatus
  method       String?
  reference    String?
  gstRate      Float?
  gstAmount    Float?
  total        Int?
  createdAt    DateTime            @default(now())
  durationDays Int?
  member       Member              @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Plan {
  id            String               @id @default(cuid())
  name          String               @unique
  level         Int
  price         Int
  currency      String               @default("INR")
  durationDays  Int
  memberLimit   Int                  @default(0)
  features      Json?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  billingCycle  BillingCycle         @default(MONTHLY)
  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt @db.Timestamp(6)
  expiryReminderSentAt DateTime?          @db.Timestamp(6)
  plan                 Plan               @relation(fields: [planId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([planId])
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  planId            String
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus
  provider          String
  providerOrderId   String
  providerPaymentId String?
  providerSignature String?
  meta              Json?
  createdAt         DateTime      @default(now())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([provider, providerPaymentId, providerOrderId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model GymMembership {
  id        String           @id @default(cuid())
  tenantId  String
  memberId  String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  member    Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model WhatsAppSetting {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  provider  String?
}

model WhatsAppLog {
  id       String   @id @default(uuid())
  tenantId String
  memberId String?
  phone    String
  type     String
  status   String
  error    String?
  sentAt   DateTime @default(now())
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  referenceId String?
  payload     Json
  receivedAt  DateTime @default(now())
}

model WebhookLog {
  id        String   @id @default(uuid())
  provider  String
  event     String
  entityId  String?
  tenantId  String?
  planId    String?
  status    String
  payload   Json
  error     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([event])
}

model GymAttendance {
  id           String           @id @default(cuid())
  tenantId     String
  memberId     String
  checkInTime  DateTime
  checkOutTime DateTime?
  source       AttendanceSource @default(MANUAL)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  member       Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Shop {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  pincode       String
  gstNumber     String?
  gstEnabled    Boolean  @default(false)
  invoicePrefix String
  logoUrl       String?
  website       String?
  invoiceFooter String?
  terms         String[] @default([])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  staff        ShopStaff[]
  jobCards     JobCard[]
  products     ShopProduct[]
  stockEntries StockLedger[]
  invoices     Invoice[]

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  financialEntries FinancialEntry[]
  purchases        Purchase[]
  receipts         Receipt[]
  paymentVouchers  PaymentVoucher[]
  quotations       Quotation[]
  purchaseOrders   PurchaseOrder[]

  @@unique([tenantId, invoicePrefix])
  @@index([tenantId])
}

model ShopStaff {
  id        String   @id @default(cuid())
  tenantId  String
  shopId    String
  userId    String
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, shopId])
  @@index([tenantId])
  @@index([shopId])
}

model JobCard {
  id       String @id @default(cuid())
  tenantId String
  shopId   String

  customerId String? // ✅ NEW (nullable)
  customer   Customer? @relation(fields: [customerId], references: [id])

  jobNumber   String
  publicToken String @unique

  // 🔒 KEEP LEGACY FIELDS FOR NOW
  customerName     String
  customerPhone    String
  customerAltPhone String?

  // Device
  deviceType     String // Mobile, Laptop, etc.
  deviceBrand    String
  deviceModel    String
  deviceSerial   String? // IMEI / SNO
  devicePassword String? // Device lock/password

  // Issue
  customerComplaint String
  physicalCondition String?

  // Financial
  estimatedCost     Int?
  diagnosticCharge  Int?      @default(0)
  advancePaid       Int       @default(0)
  finalCost         Int?
  billType          String    @default("WITHOUT_GST") // WITHOUT_GST, WITH_GST
  estimatedDelivery DateTime?

  // Advance Payment
  advancePaymentMethod String? // Cash, UPI, Mixed
  advanceCashAmount    Int?
  advanceUpiAmount     Int?

  // Consent & Warranty
  warrantyDuration     Int?    @default(0) // days
  consentAcknowledge   Boolean @default(false)
  consentDataLoss      Boolean @default(false)
  consentDiagnosticFee Boolean @default(false)

  // Meta
  createdByUserId String
  createdByName   String

  status JobStatus @default(RECEIVED)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  shop      Shop             @relation(fields: [shopId], references: [id])
  partsUsed RepairPartUsed[]

  @@unique([shopId, jobNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([customerId]) // ✅ NEW
}

model HSNCode {
  id             String          @id @default(cuid())
  code           String          @unique
  description    String?
  taxRate        Float
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  hsnProducts    GlobalProduct[]
  tenantProducts TenantProduct[]
}

model ProductCategory {
  id               String          @id @default(cuid())
  name             String          @unique
  createdAt        DateTime        @default(now())
  categoryProducts GlobalProduct[]
  tenantProducts   TenantProduct[]
}

model GlobalProduct {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  hsnId      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  category     ProductCategory @relation(fields: [categoryId], references: [id])
  hsn          HSNCode         @relation(fields: [hsnId], references: [id])
  shopProducts ShopProduct[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([hsnId])
}

// Tenant-level product master (owner-defined, shared across shops)
model TenantProduct {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  categoryId String
  hsnId      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  category     ProductCategory @relation(fields: [categoryId], references: [id])
  hsn          HSNCode         @relation(fields: [hsnId], references: [id])
  shopProducts ShopProduct[]

  @@unique([tenantId, name, categoryId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([hsnId])
}

model ShopProduct {
  id              String      @id @default(cuid())
  tenantId        String
  shopId          String
  globalProductId String?
  tenantProductId String?
  name            String
  salePrice       Int?
  costPrice       Int?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  type            ProductType // GOODS, SPARE, SERVICE
  category        String? // Free text category (e.g. Charger, Cover)
  serialNumber    String?     @unique // For GOODS, globally unique if present

  // Tax & HSN (Local override or standalone)
  hsnCode String?
  gstRate Float?  @default(0)

  // Stock & Inventory
  stockOnHand   Int     @default(0)
  reservedStock Int     @default(0)
  reorderLevel  Int?
  reorderQty    Int?
  barcode       String?
  location      String? // Physical shelf location

  imeis         IMEI[] // For MOBILE only
  stockEntries  StockLedger[]
  invoiceItems  InvoiceItem[]
  partsUsed     RepairPartUsed[]
  purchaseItems PurchaseItem[]

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  shop          Shop           @relation(fields: [shopId], references: [id])
  global        GlobalProduct? @relation(fields: [globalProductId], references: [id])
  tenantProduct TenantProduct? @relation(fields: [tenantProductId], references: [id])

  @@unique([shopId, name])
  @@index([tenantId])
  @@index([shopId])
  @@index([tenantProductId])
}

model IMEI {
  id            String      @id @default(cuid())
  tenantId      String
  shopProductId String
  imei          String      @unique
  invoiceId     String? // Linked invoice when sold; null = available
  createdAt     DateTime    @default(now())
  product       ShopProduct @relation(fields: [shopProductId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  invoice       Invoice?    @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([shopProductId])
  @@index([invoiceId])
}

model StockLedger {
  id            String         @id @default(cuid())
  tenantId      String
  shopId        String
  shopProductId String
  type          StockEntryType
  quantity      Int
  referenceType StockRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime       @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  shop    Shop        @relation(fields: [shopId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([tenantId, shopId, createdAt])
  @@index([shopProductId, createdAt])
  @@index([tenantId, shopId, type])
}

model Invoice {
  id       String @id @default(cuid())
  tenantId String
  shopId   String

  customerId String? // ✅ NEW (nullable, SAFE)
  customer   Customer? @relation(fields: [customerId], references: [id])

  invoiceNumber String
  invoiceDate   DateTime @default(now())
  financialYear String?
  customerName  String
  customerPhone String?
  customerGstin String?
  customerState String?

  subTotal    Int
  gstAmount   Int
  cgst        Int?
  sgst        Int?
  igst        Int?
  totalAmount Int

  paymentMode PaymentMode
  cashAmount  Int?
  upiAmount   Int?
  cardAmount  Int?

  status    InvoiceStatus @default(PAID)
  createdAt DateTime      @default(now())
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  items    InvoiceItem[]
  imeis    IMEI[] // IMEIs sold via this invoice
  receipts Receipt[] // Linked payments

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId]) // ✅ NEW (for history lookup)
}

model InvoiceItem {
  id            String @id @default(cuid())
  invoiceId     String
  shopProductId String
  quantity      Int
  rate          Int
  hsnCode       String
  gstRate       Float
  gstAmount     Int
  lineTotal     Int

  invoice Invoice     @relation(fields: [invoiceId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([invoiceId])
}

model RepairPartUsed {
  id            String   @id @default(cuid())
  jobCardId     String
  shopProductId String
  quantity      Int
  createdAt     DateTime @default(now())

  jobCard JobCard     @relation(fields: [jobCardId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@unique([jobCardId, shopProductId])
  @@index([jobCardId])
}

model FinancialEntry {
  id            String          @id @default(cuid())
  tenantId      String
  shopId        String
  type          FinanceType
  amount        Int
  mode          PaymentMode
  referenceType FinanceRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
}

// ============= SUPPLIER MANAGEMENT =============

model Supplier {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  namelowercase       String // For case-insensitive search
  primaryPhone        String
  altPhone            String?
  email               String?
  gstin               String?
  address             String?
  state               String?
  defaultPaymentTerms String? // e.g., '30 days', 'COD'
  defaultCreditLimit  Int?
  defaultCurrency     String   @default("INR")
  tags                String[] @default([]) // parts, accessories, etc.
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  shopSuppliers ShopSupplier[]
  purchases     Purchase[]

  @@unique([tenantId, namelowercase])
  @@index([tenantId])
}

model ShopSupplier {
  id                 String   @id @default(cuid())
  tenantId           String
  shopId             String
  globalSupplierId   String?
  name               String
  namelowercase      String // For case-insensitive search
  phone              String?
  email              String?
  gstin              String?
  outstandingAmount  Int      @default(0)
  openPurchasesCount Int      @default(0)
  localNotes         String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?

  supplier Supplier? @relation(fields: [globalSupplierId], references: [id])

  @@unique([shopId, namelowercase])
  @@index([tenantId])
  @@index([shopId])
}

// ============= GLOBAL SUPPLIERS (Available to all tenants) =============

model GlobalSupplier {
  id                  String   @id @default(cuid())
  name                String
  namelowercase       String   @unique // For case-insensitive search
  primaryPhone        String?
  altPhone            String?
  email               String?
  gstin               String?
  address             String?
  state               String?
  country             String   @default("India")
  defaultPaymentTerms String?
  defaultCreditLimit  Int?
  defaultCurrency     String   @default("INR")
  tags                String[] @default([])
  isVerified          Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  tenants TenantGlobalSupplier[]

  @@index([isActive])
  @@index([namelowercase])
}

model TenantGlobalSupplier {
  id               String   @id @default(cuid())
  tenantId         String
  globalSupplierId String
  linkedAt         DateTime @default(now())
  localName        String? // Tenant can customize the name
  localPhone       String?
  localNotes       String?

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  globalSupplier GlobalSupplier @relation(fields: [globalSupplierId], references: [id], onDelete: Cascade)

  @@unique([tenantId, globalSupplierId])
  @@index([tenantId])
  @@index([globalSupplierId])
}

// ============= PURCHASE MANAGEMENT =============

model Purchase {
  id               String    @id @default(cuid())
  tenantId         String
  shopId           String
  invoiceNumber    String
  globalSupplierId String?
  supplierName     String
  invoiceDate      DateTime  @default(now())
  dueDate          DateTime?

  subTotal   Int
  totalGst   Int
  grandTotal Int
  paidAmount Int @default(0)

  paymentMethod    PaymentMode
  paymentReference String?
  cashAmount       Int?
  upiAmount        Int?

  purchaseType String         @default("Goods") // Goods, Service
  taxInclusive Boolean        @default(false)
  status       PurchaseStatus @default(DRAFT)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  shop     Shop              @relation(fields: [shopId], references: [id])
  supplier Supplier?         @relation(fields: [globalSupplierId], references: [id])
  items    PurchaseItem[]
  payments SupplierPayment[]

  @@unique([shopId, invoiceNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([globalSupplierId])
}

model PurchaseItem {
  id            String  @id @default(cuid())
  purchaseId    String
  shopProductId String?
  description   String
  hsnSac        String?
  quantity      Int
  purchasePrice Int
  gstRate       Float   @default(0)
  taxAmount     Int     @default(0)
  totalAmount   Int

  createdAt DateTime @default(now())

  purchase Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  ShopProduct? @relation(fields: [shopProductId], references: [id])

  @@index([purchaseId])
  @@index([shopProductId])
}

// ============= SUPPLIER PAYMENTS =============

model SupplierPayment {
  id               String      @id @default(cuid())
  tenantId         String
  shopId           String
  purchaseId       String?
  globalSupplierId String?
  amount           Int
  paymentMethod    PaymentMode
  paymentReference String?
  paymentDate      DateTime    @default(now())
  notes            String?

  createdAt DateTime @default(now())
  createdBy String?

  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([purchaseId])
}

// ============= RECEIPTS & PAYMENTS =============

model Receipt {
  id             String      @id @default(cuid())
  tenantId       String
  shopId         String
  receiptId      String      @unique
  printNumber    String // Sequential print number
  receiptType    ReceiptType
  amount         Int
  paymentMethod  PaymentMode
  transactionRef String? // UPI ref, cheque number, etc.

  customerId    String?
  customerName  String
  customerPhone String?

  linkedInvoiceId String?
  linkedJobId     String?

  narration String?
  status    ReceiptStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  createdBy String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  shop    Shop     @relation(fields: [shopId], references: [id])
  invoice Invoice? @relation(fields: [linkedInvoiceId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([linkedInvoiceId])
}

model PaymentVoucher {
  id             String      @id @default(cuid())
  tenantId       String
  shopId         String
  voucherId      String      @unique
  voucherType    VoucherType
  date           DateTime    @default(now())
  amount         Int
  paymentMethod  PaymentMode
  transactionRef String?
  narration      String?

  globalSupplierId String?
  expenseCategory  String? // rent, eb, tea, donation, misc
  linkedPurchaseId String?

  status VoucherStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
}

// ============= QUOTATIONS =============

model Quotation {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String
  quotationNumber String
  customerId      String?
  customerName    String
  quotationDate   DateTime @default(now())

  items        QuotationItem[]
  totalAmount  Int             @default(0)
  notes        String?
  status       QuotationStatus @default(DRAFT)
  validityDays Int             @default(30)
  expiryDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, quotationNumber])
  @@index([tenantId])
  @@index([shopId])
}

model QuotationItem {
  id          String @id @default(cuid())
  quotationId String
  description String
  quantity    Int
  price       Int
  totalAmount Int

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

// ============= PURCHASE ORDERS =============

model PurchaseOrder {
  id               String    @id @default(cuid())
  tenantId         String
  shopId           String
  poNumber         String
  globalSupplierId String?
  supplierName     String
  orderDate        DateTime  @default(now())
  expectedDelivery DateTime?

  items                PurchaseOrderItem[]
  totalEstimatedAmount Int                 @default(0)
  notes                String?
  status               POStatus            @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, poNumber])
  @@index([tenantId])
  @@index([shopId])
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  poId             String
  globalProductId  String?
  description      String
  quantity         Int
  estimatedPrice   Int?
  receivedQuantity Int     @default(0)

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}

