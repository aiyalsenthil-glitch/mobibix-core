  shopProductId String?
  description   String
  quantity      Int
  price         Int
  gstRate       Float        @default(0)
  gstAmount     Int          @default(0)
  lineTotal     Int          @default(0)
  totalAmount   Int

  quotation Quotation    @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   ShopProduct? @relation(fields: [shopProductId], references: [id])

  @@index([quotationId])
  @@map("mb_quotation_item")
}

model PurchaseOrder {
  id                   String              @id @default(cuid())
  tenantId             String
  shopId               String
  poNumber             String
  globalSupplierId     String?
  supplierName         String
  party                Party?              @relation(fields: [globalSupplierId], references: [id])
  orderDate            DateTime            @default(now())
  expectedDelivery     DateTime?
  totalEstimatedAmount Int                 @default(0)
  notes                String?
  status               POStatus            @default(DRAFT)
  currency             String              @default("INR")
  exchangeRate         Decimal             @default(1.0) @db.Decimal(18, 6)
  paymentDueDays       Int                 @default(30)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdBy            String?
  shop                 Shop                @relation(fields: [shopId], references: [id])
  tenant               Tenant              @relation("TenantPurchaseOrders", fields: [tenantId], references: [id])
