  createdBy     String?
  createdAt     DateTime    @default(now())
  shop          Shop        @relation(fields: [shopId], references: [id])
  product       ShopProduct @relation(fields: [shopProductId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, shopId])
  @@index([shopProductId])
  @@index([createdAt])
  @@map("mb_stock_correction")
}

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  shopId          String
  customerId      String?
  invoiceNumber   String
  invoiceDate     DateTime      @default(now())
  financialYear   String?
  customerName    String
  customerPhone   String?
  customerGstin   String?
  customerState   String?
  shopGstin       String? // P0 GST Compliance: seller GSTIN snapshot at invoice time
  subTotal        Int
  gstAmount       Int
  cgst            Int?
  sgst            Int?
  igst            Int?
  totalAmount     Int
  paidAmount      Int           @default(0)
  paymentMode     PaymentMode
  cashAmount      Int?
  upiAmount       Int?
  cardAmount      Int?
  status          InvoiceStatus @default(UNPAID)
  invoiceType     InvoiceType   @default(SALES)
  isGstApplicable Boolean       @default(true)
  currency        String        @default("INR") // Snapshot at invoice time — never changes
  taxDetails      Json? // Localized tax breakdown (strategy-aware)
  jobCardId       String? // Link to JobCard for auto-generated invoices
  voidReason      String? // Reason for void (e.g., "Job cancelled")
  voidedAt        DateTime?
  createdAt       DateTime      @default(now())
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?

  imeis    IMEI[]
  customer Party?        @relation(fields: [customerId], references: [id])
  shop     Shop          @relation(fields: [shopId], references: [id])
  tenant   Tenant        @relation("TenantInvoices", fields: [tenantId], references: [id])
  jobCard  JobCard?      @relation("JobCardInvoices", fields: [jobCardId], references: [id])
  items    InvoiceItem[]
  receipts Receipt[]

  quotations               Quotation[]              @relation("QuotationToInvoice")
  creditNotes              CreditNote[]             @relation("InvoiceCreditNotes")
  creditNoteApplications   CreditNoteApplication[]  @relation("InvoiceCNApplications")

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([tenantId, invoiceDate])
  @@index([shopId, invoiceDate])
  @@index([tenantId, shopId, createdAt])
  @@index([tenantId, deletedAt])
  @@map("mb_invoice")
}

model InvoiceItem {
  id            String  @id @default(cuid())
  invoiceId     String
  shopProductId String
  quantity      Int
  rate          Int
  costAtSale    Int? // Last Purchase Price at the time of sale for GP calculations
  hsnCode       String
  gstRate       Float
  gstAmount     Int
  cgstRate      Decimal @default(9.0)
  sgstRate      Decimal @default(9.0)
  igstRate      Decimal @default(0.0)
  cgstAmount    Int?
  sgstAmount    Int?
  igstAmount    Int?
  lineTotal     Int
  taxDetails    Json? // Per-item tax breakdown

  // Warranty & Tracking
  warrantyDays  Int?
  warrantyEndAt DateTime?
  serialNumbers String[]  @default([])

  invoice Invoice     @relation(fields: [invoiceId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([invoiceId])
  @@map("mb_invoice_item")
}

model JobCardPart {
  id            String      @id @default(cuid())
  jobCardId     String
  shopProductId String
  quantity      Int
  costPrice     Int? // Historical cost at time of addition
  isDeducted    Boolean     @default(false) // Whether stock has been deducted from ledger
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  jobCard       JobCard     @relation(fields: [jobCardId], references: [id])
  product       ShopProduct @relation(fields: [shopProductId], references: [id])

  @@unique([jobCardId, shopProductId])
  @@index([jobCardId])
  @@index([shopProductId])
  @@map("mb_job_card_part")
}

model FinancialEntry {
  id            String          @id @default(cuid())
  tenantId      String
  shopId        String
  type          FinanceType
  amount        Int
  mode          PaymentMode
  referenceType FinanceRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime        @default(now())
  shop          Shop            @relation(fields: [shopId], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@map("mb_financial_entry")
}

model Purchase {
  id                       String         @id @default(cuid())
  tenantId                 String
  shopId                   String
  invoiceNumber            String
  globalSupplierId         String?
  supplierName             String
  supplierGstin            String?        @db.VarChar(15)
  invoiceDate              DateTime       @default(now())
  dueDate                  DateTime?
  subTotal                 Int
  totalGst                 Int
  cgst                     Int?           @default(0)
  sgst                     Int?           @default(0)
  igst                     Int?           @default(0)
  grandTotal               Int
  paidAmount               Int            @default(0)
  paymentMethod            PaymentMode
  paymentReference         String?
  cashAmount               Int?
  upiAmount                Int?
  purchaseType             String         @default("Goods")
  taxInclusive             Boolean        @default(false)
  isLegacyGstApproximation Boolean        @default(false)
  gstApproximationReason   String?
  verifiedByUserId         String?
  verifiedAt               DateTime?
  status                   PurchaseStatus @default(DRAFT)
  notes                    String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  createdBy                String?
  currency                 String         @default("INR")
  taxDetails               Json? // Localized tax breakdown
  exchangeRate             Decimal        @default(1.0) @db.Decimal(18, 6)
  poId                     String?

  po               PurchaseOrder?       @relation(fields: [poId], references: [id])
  party            Party?               @relation("PartyToPurchases", fields: [globalSupplierId], references: [id])
  shop             Shop                 @relation(fields: [shopId], references: [id])
  tenant           Tenant               @relation("TenantPurchases", fields: [tenantId], references: [id])
  items            PurchaseItem[]
  payments         SupplierPayment[]
  supplierAdvances AdvanceApplication[]

  creditNotes            CreditNote[]            @relation("PurchaseCreditNotes")
  creditNoteApplications CreditNoteApplication[] @relation("PurchaseCNApplications")

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([globalSupplierId])
  @@map("mb_purchase")
}

model PurchaseItem {
  id            String       @id @default(cuid())
  purchaseId    String
  shopProductId String?
  description   String
  hsnSac        String?
  quantity      Int
  purchasePrice Int
  gstRate       Float        @default(0)
  cgstRate      Decimal      @default(9.0)
  sgstRate      Decimal      @default(9.0)
  igstRate      Decimal      @default(0.0)
  taxAmount     Int          @default(0)
  cgstAmount    Int?
  sgstAmount    Int?
  igstAmount    Int?
  totalAmount   Int
  taxDetails    Json? // Per-item tax breakdown
  createdAt     DateTime     @default(now())
  purchase      Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product       ShopProduct? @relation(fields: [shopProductId], references: [id])

  @@index([purchaseId])
  @@index([shopProductId])
  @@map("mb_purchase_item")
}

model SupplierPayment {
  id               String      @id @default(cuid())
