  // WhatsApp Engine Provider Support
  provider           WhatsAppProviderType       @default(META_CLOUD)
  setupStatus        WhatsAppSetupStatus        @default(ACTIVE)

  // Web-specific (Baileys) fields
  shardId            Int                        @default(0)
  webSessionId       String?                    @unique
  webSessionData     String?                    @db.Text

  // Authkey CPaaS fields
  REMOVED_TOKENApiKey      String?                    // Encrypted API key for Authkey
  REMOVED_TOKENSenderId    String?                    // Authkey sender ID / SID
  REMOVED_TOKENCountryCode String?    @default("91") // Default country code for outbound messages
  REMOVED_TOKENVerifiedAt  DateTime?                  // Set on first successful test send
  lastTestSentAt     DateTime?                  // Last time a test message was sent

  // Meta-specific fields
  metaUserId         String?                    // FB user_id who connected — required for Data Deletion Callback
  tokenExpiresAt     DateTime?                  // For user tokens; null = system user (no expiry)

  metadata           Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  lastProviderSwitchAt DateTime?

  // Relations
  tenant             Tenant?                    @relation("TenantWhatsAppNumbers", fields: [tenantId], references: [id])
  reminderForTenants Tenant[]                   @relation("TenantReminderNumber")
  logs               WhatsAppLog[]
  messageLogs        WhatsAppMessageLog[]
  campaigns          WhatsAppCampaign[]

  @@index([tenantId, isEnabled])
