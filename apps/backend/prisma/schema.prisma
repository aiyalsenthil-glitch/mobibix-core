  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  subscriptionInvoice SubscriptionInvoice? @relation("PaymentToSubscriptionInvoice")
  retries             PaymentRetry[]

  @@unique([provider, providerPaymentId, providerOrderId])
  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@index([module, createdAt(sort: Desc)])
}

model PaymentRetry {
  id            String             @id @default(cuid())
