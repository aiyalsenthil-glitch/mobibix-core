  purchase         Purchase       @relation(fields: [purchaseId], references: [id])

  @@unique([advanceVoucherId, purchaseId])
  @@index([advanceVoucherId])
  @@index([purchaseId])
  @@map("mb_advance_application")
}

model Quotation {
  id              String          @id @default(cuid())
  tenantId        String
  shopId          String
  quotationNumber String
  customerId      String?
  customerName    String
  customerPhone   String?
  quotationDate   DateTime        @default(now())
  subTotal        Int             @default(0)
  gstAmount       Int             @default(0)
  totalAmount     Int             @default(0)
  notes           String?
  status          QuotationStatus @default(DRAFT)
  validityDays    Int             @default(30)
  expiryDate      DateTime?

  // Conversion tracking
  linkedInvoiceId  String?
  linkedJobCardId  String?
  conversionType   QuotationConversionType?
  convertedAt      DateTime?
  convertedBy      String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String?

  party         Party?          @relation(fields: [customerId], references: [id])
  shop          Shop            @relation(fields: [shopId], references: [id])
  tenant        Tenant          @relation("TenantQuotations", fields: [tenantId], references: [id])
  linkedInvoice Invoice?        @relation("QuotationToInvoice", fields: [linkedInvoiceId], references: [id])
  linkedJobCard JobCard?        @relation("QuotationToJobCard", fields: [linkedJobCardId], references: [id])
  items         QuotationItem[]

  @@unique([shopId, quotationNumber])
  @@index([tenantId])
  @@index([shopId])
  @@map("mb_quotation")
}

model QuotationItem {
  id            String       @id @default(cuid())
