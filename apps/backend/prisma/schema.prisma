generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String               @id @default(cuid())
  name             String
  legalName        String?
  tenantType       String
  code             String               @unique
  contactPhone     String
  contactEmail     String?
  website          String?
  logoUrl          String?
  addressLine1     String
  addressLine2     String?
  city             String
  state            String
  pincode          String
  country          String               @default("India")
  gstNumber        String?
  taxId            String?
  businessType     String?
  currency         String               @default("INR")
  timezone         String               @default("Asia/Kolkata")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  kioskToken       String?              @unique
  maxMembers       Int                  @default(50)
  whatsappEnabled  Boolean              @default(true)
  auditLogs        AuditLog[]
  members          Member[]
  payments         Payment[]
  subscription     TenantSubscription[]
  users            User[]
  userTenants      UserTenant[]
  shops            Shop[]
  shopStaffs       ShopStaff[]
  jobCards         JobCard[]
  shopProducts     ShopProduct[]
  stockEntries     StockLedger[]
  invoices         Invoice[]
  financialEntries FinancialEntry[]
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model User {
  id               String       @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid      String       @unique
  email            String?
  fullName         String?
  avatar           String?
  role             UserRole
  tenantId         String?
  permissions      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  phone            String?
  welcomeEmailSent Boolean      @default(false)
  auditLogs        AuditLog[]
  tenant           Tenant?      @relation(fields: [tenantId], references: [id])
  userTenants      UserTenant[]
  shopStaffs       ShopStaff[]
}

model Member {
  id                  String              @id @default(uuid())
  tenantId            String
  fullName            String
  phone               String
  gender              Gender
  membershipPlanId    String
  membershipStartAt   DateTime
  membershipEndAt     DateTime
  feeAmount           Int
  paymentStatus       MemberPaymentStatus
  heightCm            Float
  weightKg            Float
  fitnessGoal         FitnessGoal
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  paidAmount          Int                 @default(0)
  monthlyFee          Int
  paymentDueDate      DateTime
  paymentReminderSent Boolean             @default(false)
  isActive            Boolean             @default(true)
  photoUrl            String?
  welcomeMessageSent  Boolean             @default(false)
  attendances         GymAttendance[]
  gymMemberships      GymMembership[]
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  payments            MemberPayment[]

  @@unique([id, tenantId])
  @@unique([tenantId, phone])
  @@index([tenantId])
}

model StaffInvite {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  createdAt DateTime @default(now())
  accepted  Boolean  @default(false)
  role      UserRole @default(STAFF)
  name      String?
  phone     String?

  @@unique([tenantId, email])
}

model MemberPayment {
  id           String              @id @default(cuid())
  tenantId     String
  memberId     String
  amount       Int
  status       MemberPaymentStatus
  method       String?
  reference    String?
  gstRate      Float?
  gstAmount    Float?
  total        Int?
  createdAt    DateTime            @default(now())
  durationDays Int?
  member       Member              @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Plan {
  id            String               @id @default(cuid())
  name          String               @unique
  level         Int
  price         Int
  currency      String               @default("INR")
  durationDays  Int
  memberLimit   Int                  @default(0)
  features      Json?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  billingCycle  BillingCycle         @default(MONTHLY)
  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt @db.Timestamp(6)
  expiryReminderSentAt DateTime?          @db.Timestamp(6)
  plan                 Plan               @relation(fields: [planId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([planId])
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  planId            String
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus
  provider          String
  providerOrderId   String
  providerPaymentId String?
  providerSignature String?
  meta              Json?
  createdAt         DateTime      @default(now())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([provider, providerPaymentId, providerOrderId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model GymMembership {
  id        String           @id @default(cuid())
  tenantId  String
  memberId  String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  member    Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model WhatsAppSetting {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  provider  String?
}

model WhatsAppLog {
  id       String   @id @default(uuid())
  tenantId String
  memberId String?
  phone    String
  type     String
  status   String
  error    String?
  sentAt   DateTime @default(now())
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  referenceId String?
  payload     Json
  receivedAt  DateTime @default(now())
}

model WebhookLog {
  id        String   @id @default(uuid())
  provider  String
  event     String
  entityId  String?
  tenantId  String?
  planId    String?
  status    String
  payload   Json
  error     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([event])
}

model GymAttendance {
  id           String           @id @default(cuid())
  tenantId     String
  memberId     String
  checkInTime  DateTime
  checkOutTime DateTime?
  source       AttendanceSource @default(MANUAL)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  member       Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Shop {
  id            String        @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  pincode       String
  gstNumber     String?
  invoicePrefix String
  logoUrl       String?
  website       String?
  invoiceFooter String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  staff         ShopStaff[]
  jobCards      JobCard[]
  products      ShopProduct[]
  stockEntries  StockLedger[]
  invoices      Invoice[]

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  financialEntries FinancialEntry[]

  @@unique([tenantId, invoicePrefix])
  @@index([tenantId])
}

model ShopStaff {
  id        String   @id @default(cuid())
  tenantId  String
  shopId    String
  userId    String
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, shopId])
  @@index([tenantId])
  @@index([shopId])
}

model JobCard {
  id            String    @id @default(cuid())
  tenantId      String
  shopId        String
  jobNumber     String
  publicToken   String    @unique
  customerName  String
  customerPhone String
  deviceBrand   String
  deviceModel   String
  imei          String?
  problem       String
  status        JobStatus @default(RECEIVED)
  estimatedCost Int?
  finalCost     Int?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, jobNumber])
  @@index([tenantId])
  @@index([shopId])
}

model HSNCode {
  id          String          @id @default(cuid())
  code        String          @unique
  taxRate     Float
  createdAt   DateTime        @default(now())
  hsnProducts GlobalProduct[]
}

model ProductCategory {
  id               String          @id @default(cuid())
  name             String          @unique
  createdAt        DateTime        @default(now())
  categoryProducts GlobalProduct[]
}

model GlobalProduct {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  hsnId      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  category     ProductCategory @relation(fields: [categoryId], references: [id])
  hsn          HSNCode         @relation(fields: [hsnId], references: [id])
  shopProducts ShopProduct[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([hsnId])
}

model ShopProduct {
  id              String        @id @default(cuid())
  tenantId        String
  shopId          String
  globalProductId String?
  name            String
  salePrice       Int?
  costPrice       Int?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  stockEntries    StockLedger[]
  invoiceItems    InvoiceItem[]

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  shop   Shop           @relation(fields: [shopId], references: [id])
  global GlobalProduct? @relation(fields: [globalProductId], references: [id])

  @@unique([shopId, name])
  @@index([tenantId])
  @@index([shopId])
}

model StockLedger {
  id            String         @id @default(cuid())
  tenantId      String
  shopId        String
  shopProductId String
  type          StockEntryType
  quantity      Int
  referenceType StockRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime       @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  shop    Shop        @relation(fields: [shopId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([shopProductId])
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  shopId        String
  invoiceNumber String
  invoiceDate   DateTime      @default(now())
  customerName  String
  customerPhone String?
  subTotal      Int
  gstAmount     Int
  totalAmount   Int
  paymentMode   PaymentMode
  status        InvoiceStatus @default(PAID)
  createdAt     DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  items InvoiceItem[]

  @@unique([shopId, invoiceNumber])
  @@index([tenantId])
  @@index([shopId])
}

model InvoiceItem {
  id            String @id @default(cuid())
  invoiceId     String
  shopProductId String
  quantity      Int
  rate          Int
  hsnCode       String
  gstRate       Float
  gstAmount     Int
  lineTotal     Int

  invoice Invoice     @relation(fields: [invoiceId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([invoiceId])
}

model FinancialEntry {
  id            String          @id @default(cuid())
  tenantId      String
  shopId        String
  type          FinanceType
  amount        Int
  mode          PaymentMode
  referenceType FinanceRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
}

enum FinanceType {
  IN
  OUT
}

enum FinanceRefType {
  INVOICE
  JOB
  PURCHASE
  ADJUSTMENT
}

enum JobStatus {
  RECEIVED
  DIAGNOSING
  WAITING_FOR_PARTS
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  PAID
  CANCELLED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  BANK
}

enum StockEntryType {
  IN
  OUT
}

enum StockRefType {
  PURCHASE
  SALE
  REPAIR
  ADJUSTMENT
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum UserRole {
  ADMIN
  OWNER
  STAFF
  USER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  GENERAL_FITNESS
  WEIGHT_GAIN
}

enum MemberPaymentStatus {
  PAID
  DUE
  PARTIAL
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  SCHEDULED
}

enum AttendanceSource {
  MANUAL
  QR
  BIOMETRIC
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
}
