generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String                 @id @default(cuid())
  name                String
  legalName           String?
  tenantType          String
  code                String                 @unique
  contactPhone        String?
  contactEmail        String?
  website             String?
  logoUrl             String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  state               String?
  pincode             String?
  country             String                 @default("India")
  gstNumber           String?
  taxId               String?
  businessType        String?
  currency            String                 @default("INR")
  timezone            String                 @default("Asia/Kolkata")
  createdAt           DateTime               @default(now())
  createdBy           String?
  updatedAt           DateTime               @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  kioskToken          String?                @unique
  maxMembers          Int                    @default(50)
  whatsappEnabled     Boolean                @default(true)
  whatsappCrmEnabled  Boolean                @default(false)
  whatsappPhoneNumberId String?
  auditLogs           AuditLog[]
  parties             Party[]                @relation("TenantParties")
  customerAlerts      CustomerAlert[]        @relation("TenantCustomerAlerts")
  customerFollowUps   CustomerFollowUp[]     @relation("TenantCustomerFollowUps")
  customerReminders   CustomerReminder[]     @relation("TenantCustomerReminders")
  financialEntries    FinancialEntry[]
  imeis               IMEI[]
  invoices            Invoice[]              @relation("TenantInvoices")
  jobCards            JobCard[]              @relation("TenantJobCards")
  ledgerAccounts      LedgerAccount[]
  ledgerCustomers     LedgerCustomer[]
  supplierPayments    SupplierPayment[]      @relation("TenantSupplierPayments")
  loyaltyTransactions LoyaltyTransaction[]
  members             Member[]               @relation("TenantMembers")
  payments            Payment[]
  paymentVouchers     PaymentVoucher[]       @relation("TenantPaymentVouchers")
  purchases           Purchase[]             @relation("TenantPurchases")
  purchaseOrders      PurchaseOrder[]        @relation("TenantPurchaseOrders")
  quotations          Quotation[]            @relation("TenantQuotations")
  receipts            Receipt[]              @relation("TenantReceipts")
  shops               Shop[]
  shopProducts        ShopProduct[]
  shopStaffs          ShopStaff[]
  stockCorrections    StockCorrection[]
  stockEntries        StockLedger[]          @relation("TenantStockEntries")
  subscription        TenantSubscription[]
  users               User[]
  userTenants         UserTenant[]
  whatsAppCampaigns   WhatsAppCampaign[]
  whatsAppUsage       WhatsAppDailyUsage[]
  usageSnapshots      UsageSnapshot[]
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model User {
  id                String             @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid       String             @unique
  email             String?
  fullName          String?
  avatar            String?
  role              UserRole
  tenantId          String?
  permissions       Json?
  createdAt         DateTime           @default(now())
  createdBy         String?
  updatedAt         DateTime           @updatedAt
  updatedBy         String?
  deletedAt         DateTime?
  deletedBy         String?
  phone             String?
  welcomeEmailSent  Boolean            @default(false)
  auditLogs         AuditLog[]
  assignedFollowUps CustomerFollowUp[]
  platformAuditLogs PlatformAuditLog[]
  shopStaffs        ShopStaff[]
  tenant            Tenant?            @relation(fields: [tenantId], references: [id])
  userTenants       UserTenant[]
}

model Member {
  id                  String              @id @default(uuid())
  tenantId            String
  fullName            String
  phone               String
  gender              Gender
  membershipPlanId    String
  membershipStartAt   DateTime
  membershipEndAt     DateTime
  feeAmount           Int
  paymentStatus       MemberPaymentStatus
  heightCm            Float
  weightKg            Float
  fitnessGoal         FitnessGoal
  createdAt           DateTime            @default(now())
  createdBy           String?
  updatedAt           DateTime            @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  paidAmount          Int                 @default(0)
  monthlyFee          Int
  paymentDueDate      DateTime
  paymentReminderSent Boolean             @default(false)
  isActive            Boolean             @default(true)
  photoUrl            String?
  welcomeMessageSent  Boolean             @default(false)
  hasCoaching         Boolean             @default(false)
  customerId          String?
  attendances         GymAttendance[]
  gymMemberships      GymMembership[]
  customer            Party?           @relation(fields: [customerId], references: [id])
  tenant              Tenant              @relation("TenantMembers", fields: [tenantId], references: [id])
  payments            MemberPayment[]

  @@unique([id, tenantId])
  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Party {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  phone               String
  email               String?
  state               String?
  gstNumber           String?
  businessType        BusinessType         @default(B2C)
  partyType           PartyType            @default(CUSTOMER)
  loyaltyPoints       Int                  @default(0)
  isActive            Boolean              @default(true)
  altPhone            String?
  address             String?
  defaultPaymentTerms String?
  defaultCreditLimit  Int?
  defaultCurrency     String               @default("INR")
  tags                String[]             @default([])
  createdBy           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenant              Tenant               @relation("TenantParties", fields: [tenantId], references: [id])
  alerts              CustomerAlert[]
  followUps           CustomerFollowUp[]
  reminders           CustomerReminder[]
  invoices            Invoice[]
  jobCards            JobCard[]
  loyaltyTransactions LoyaltyTransaction[]
  members             Member[]
  purchases           Purchase[]           @relation("PartyToPurchases")
  supplierPayments    SupplierPayment[]
  receipts            Receipt[]
  quotations          Quotation[]
  purchaseOrders      PurchaseOrder[]
  paymentVouchers     PaymentVoucher[]
  whatsAppLogs        WhatsAppLog[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model CustomerFollowUp {
  id               String          @id @default(cuid())
  tenantId         String
  customerId       String
  shopId           String?
  type             FollowUpType
  purpose          FollowUpPurpose
  note             String?
  followUpAt       DateTime
  status           FollowUpStatus  @default(PENDING)
  assignedToUserId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  assignedToUser   User?           @relation(fields: [assignedToUserId], references: [id])
  customer         Party        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop             Shop?           @relation(fields: [shopId], references: [id])
  tenant           Tenant          @relation("TenantCustomerFollowUps", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([shopId])
  @@index([assignedToUserId])
  @@index([followUpAt])
  @@index([status])
}

model CustomerReminder {
  id            String              @id @default(cuid())
  tenantId      String
  customerId    String
  triggerType   ReminderTriggerType
  triggerValue  String
  channel       ReminderChannel
  templateKey   String
  status        ReminderStatus      @default(SCHEDULED)
  scheduledAt   DateTime?
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  customer      Party            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation("TenantCustomerReminders", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
}

model LoyaltyTransaction {
  id          String        @id @default(cuid())
  tenantId    String
  customerId  String
  points      Int
  source      LoyaltySource
  referenceId String?
  note        String?
  createdAt   DateTime      @default(now())
  customer    Party         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant      Tenant        @relation(fields: [tenantId], references: [id])


  @@index([tenantId])
  @@index([customerId])
  @@index([createdAt])
}

model CustomerAlert {
  id         String        @id @default(cuid())
  tenantId   String
  customerId String
  severity   AlertSeverity
  message    String
  source     AlertSource
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  customer   Party      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant     Tenant        @relation("TenantCustomerAlerts", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
}

model LedgerCustomer {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  address   String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  ledgers   LedgerAccount[]
  tenant    Tenant          @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model LedgerAccount {
  id                String                @id @default(cuid())
  tenantId          String
  customerId        String
  principalAmount   Int
  expectedTotal     Int
  installmentType   LedgerInstallmentType
  installmentAmount Int
  totalPeriods      Int
  startDate         DateTime
  status            LedgerStatus          @default(ACTIVE)
  createdAt         DateTime              @default(now())
  customer          LedgerCustomer        @relation(fields: [customerId], references: [id])
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  collections       LedgerCollection[]

  @@index([tenantId])
  @@index([customerId])
}

model LedgerCollection {
  id        String        @id @default(cuid())
  tenantId  String
  ledgerId  String
  periodNo  Int
  dueDate   DateTime
  amount    Int
  paid      Boolean       @default(false)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  ledger    LedgerAccount @relation(fields: [ledgerId], references: [id])

  @@index([tenantId])
  @@index([ledgerId])
}

model StaffInvite {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  createdAt DateTime @default(now())
  accepted  Boolean  @default(false)
  role      UserRole @default(STAFF)
  name      String?
  phone     String?

  @@unique([tenantId, email])
}

model MemberPayment {
  id           String              @id @default(cuid())
  tenantId     String
  memberId     String
  amount       Int
  status       MemberPaymentStatus
  method       String?
  reference    String?
  gstRate      Float?
  gstAmount    Float?
  total        Int?
  createdAt    DateTime            @default(now())
  durationDays Int?
  member       Member              @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Plan {
  id            String               @id @default(uuid())
  code          String               @unique
  name          String               @unique
  level         Int
  module        ModuleType
  isActive      Boolean              @default(true)
  isPublic      Boolean              @default(true)
  isAddon       Boolean              @default(false)
  tagline       String?
  description   String?
  featuresJson  Json?                // For detailed feature list/UI display (frontend only)
  meta          Json?                // For add-on config (e.g. { "quota": { "utility": 500 } })
  
  // Plan Limits (moved from hardcoded PLAN_LIMITS)
  maxStaff                Int?                 // null = unlimited (applies to all modules)
  maxMembers              Int?                 // null = unlimited (GYM only - Mobibix has unlimited Parties)
  maxShops                Int?                 // null = unlimited (Mobile Shop)
  whatsappUtilityQuota    Int                  @default(0) // Monthly quota (all modules)
  whatsappMarketingQuota  Int                  @default(0) // Monthly quota (all modules)
  analyticsHistoryDays    Int                  @default(30) // Days of analytics history (all modules)
  
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  planFeatures        PlanFeature[]
  subscriptions       TenantSubscription[]
  planPrices          PlanPrice[]
  addonSubscriptions  SubscriptionAddon[]  @relation("AddonPlans") // When this plan is used as an add-on
}

model PlanPrice {
  id            String       @id @default(cuid())
  planId        String
  billingCycle  BillingCycle
  price         Int          // Price in paise (₹0.01 units)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  plan          Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, billingCycle])
  @@index([planId])
}

model PlanFeature {
  id      String          @id @default(uuid())
  planId  String
  feature WhatsAppFeature
  enabled Boolean         @default(true)
  plan    Plan            @relation(fields: [planId], references: [id])

  @@unique([planId, feature])
  @@index([planId])
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  module               ModuleType         @default(MOBILE_SHOP)
  status               SubscriptionStatus
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt @db.Timestamp(6)
  expiryReminderSentAt DateTime?          @db.Timestamp(6)
  
  // Phase 1: Billing Migration Fields
  billingCycle         BillingCycle?      // MONTHLY, QUARTERLY, YEARLY (null = use plan.billingCycle for compat)
  priceSnapshot        Int?               // Price locked at subscription creation (paise)
  autoRenew            Boolean            @default(true) // Auto-renew enabled by default
  nextPlanId           String?            // For scheduled downgrades
  nextBillingCycle     BillingCycle?      // For scheduled duration changes
  nextPriceSnapshot    Int?               // Price for next cycle (when upgrading)
  lastRenewedAt        DateTime?          // Track when last renewed (for audit)
  
  plan                 Plan                 @relation(fields: [planId], references: [id])
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  addons               SubscriptionAddon[]  // Add-ons attached to this subscription

  @@unique([tenantId, module])
  @@index([tenantId])
  @@index([planId])
  @@index([module])
  @@index([autoRenew])
}

model SubscriptionAddon {
  id             String             @id @default(cuid())
  subscriptionId String             // Reference to base subscription
  addonPlanId    String             // Reference to add-on plan (e.g., WHATSAPP_CRM)
  status         SubscriptionStatus @default(ACTIVE)
  startDate      DateTime
  endDate        DateTime
  
  // Billing fields
  billingCycle   BillingCycle?      // MONTHLY, QUARTERLY, YEARLY
  priceSnapshot  Int?               // Price locked at addon creation (paise)
  autoRenew      Boolean            @default(true)
  
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  subscription   TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  addonPlan      Plan               @relation("AddonPlans", fields: [addonPlanId], references: [id])
  
  @@unique([subscriptionId, addonPlanId])
  @@index([subscriptionId])
  @@index([addonPlanId])
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  planId            String
  billingCycle      BillingCycle
  priceSnapshot     Int
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus
  provider          String
  providerOrderId   String
  providerPaymentId String?
  providerSignature String?
  meta              Json?
  createdAt         DateTime      @default(now())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([provider, providerPaymentId, providerOrderId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model PlatformAuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model GymMembership {
  id        String           @id @default(cuid())
  tenantId  String
  memberId  String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  member    Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model WhatsAppSetting {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  enabled                Boolean  @default(false)
  createdAt              DateTime @default(now())
  provider               String?
  defaultLanguage        String   @default("en")
  dailyLimit             Int?
  testPhone              String?
  marketingOptInRequired Boolean  @default(true)
}

model WhatsAppPhoneNumber {
  id            String                     @id @default(uuid())
  tenantId      String
  phoneNumber   String
  phoneNumberId String
  wabaId        String
  purpose       WhatsAppPhoneNumberPurpose @default(DEFAULT)
  qualityRating String?
  isDefault     Boolean                    @default(false)
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@unique([tenantId, phoneNumberId])
  @@index([tenantId, isActive])
  @@index([tenantId, purpose])
}

model WhatsAppLog {
  id          String    @id @default(uuid())
  tenantId    String
  memberId    String?
  customerId  String?
  phone       String
  type        String
  status      String
  error       String?
  messageId   String?
  metadata    Json?
  sentAt      DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  deliveredAt DateTime?
  readAt      DateTime?

  customer Party? @relation(fields: [customerId], references: [id])

  @@index([tenantId, sentAt])
  @@index([tenantId, status])
  @@index([messageId])
}

model WhatsAppTemplate {
  id               String   @id @default(uuid())
  moduleType       String
  templateKey      String
  metaTemplateName String
  category         String
  feature          String
  language         String   @default("en")
  status           String   @default("ACTIVE")
  isDefault        Boolean  @default(false)
  variables        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaigns        WhatsAppCampaign[]

  @@unique([moduleType, metaTemplateName])
  @@index([moduleType])
  @@index([moduleType, templateKey])
}

model WhatsAppAutomation {
  id            String     @id @default(uuid())
  moduleType    ModuleType
  eventType     String
  templateKey   String
  offsetDays    Int
  enabled       Boolean    @default(true)
  conditions    Json?
  description   String?
  requiresOptIn Boolean    @default(false)
  createdBy     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([moduleType, eventType])
  @@index([moduleType])
}

model WhatsAppDailyUsage {
  id             String   @id @default(uuid())
  tenantId       String
  date           DateTime @db.Date // Stores just the date part (midnight)
  
  marketing      Int      @default(0)
  utility        Int      @default(0)
  service        Int      @default(0)
  authentication Int      @default(0)
  
  totalCost      Float    @default(0) // Estimated cost in base currency (INR)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId])
  @@index([date])
}

model UsageSnapshot {
  id              String   @id @default(uuid())
  tenantId        String
  date            DateTime @db.Date // Midnight
  
  activeMembers   Int      @default(0)
  activeStaff     Int      @default(0)
  activeShops     Int      @default(0)
  
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([date])
}

model WhatsAppCampaign {
  id           String                 @id @default(uuid())
  tenantId     String
  name         String
  templateId   String?
  templateName String?
  status       WhatsAppCampaignStatus @default(DRAFT)
  scheduledAt  DateTime?
  filters      Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id])
  template WhatsAppTemplate?  @relation(fields: [templateId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  referenceId String?
  payload     Json
  receivedAt  DateTime @default(now())
}

model WebhookLog {
  id        String   @id @default(uuid())
  provider  String
  event     String
  entityId  String?
  tenantId  String?
  planId    String?
  status    String
  payload   Json
  error     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([event])
}

model GymAttendance {
  id           String           @id @default(cuid())
  tenantId     String
  memberId     String
  checkInTime  DateTime
  checkOutTime DateTime?
  source       AttendanceSource @default(MANUAL)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  member       Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Shop {
  id                  String                @id @default(cuid())
  tenantId            String
  name                String
  phone               String
  addressLine1        String
  addressLine2        String?
  city                String
  state               String
  pincode             String
  gstNumber           String?
  gstEnabled          Boolean               @default(false)
  currency            String                @default("INR")
  invoicePrefix       String
  logoUrl             String?
  website             String?
  invoiceFooter       String?
  invoicePrinterType  String?               @default("NORMAL")
  invoiceTemplate     String?               @default("CLASSIC")
  jobCardPrinterType  String?               @default("NORMAL")
  jobCardTemplate     String?               @default("SIMPLE")
  headerConfig        Json?
  tagline             String?
  terms               String[]              @default([])
  repairInvoiceNumberingMode RepairInvoiceNumberingMode @default(SHARED)
  repairGstDefault           Boolean                    @default(false)
  bankName            String?
  accountNumber       String?
  ifscCode            String?
  branchName          String?
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  createdBy           String?
  updatedAt           DateTime              @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  receiptPrintCounter Int                   @default(0)
  followUps           CustomerFollowUp[]
  financialEntries    FinancialEntry[]
  transferredIMEIs    IMEI[]                @relation("TransferredIMEIs")
  invoices            Invoice[]
  jobCards            JobCard[]
  paymentVouchers     PaymentVoucher[]
  purchases           Purchase[]
  purchaseOrders      PurchaseOrder[]
  quotations          Quotation[]
  receipts            Receipt[]
  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  documentSettings    ShopDocumentSetting[]
  products            ShopProduct[]
  staff               ShopStaff[]
  stockCorrections    StockCorrection[]
  stockEntries        StockLedger[] 

  @@unique([tenantId, invoicePrefix])
  @@index([tenantId])
}

model ShopDocumentSetting {
  id            String       @id @default(cuid())
  shopId        String
  documentType  DocumentType
  prefix        String
  separator     String       @default("-")
  documentCode  String
  yearFormat    YearFormat   @default(FY)
  numberLength  Int          @default(4)
  resetPolicy   ResetPolicy  @default(YEARLY)
  currentNumber Int          @default(0)
  currentYear   String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  shop          Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, documentType])
  @@index([shopId])
  @@index([documentType])
}

model ShopStaff {
  id        String   @id @default(cuid())
  tenantId  String
  shopId    String
  userId    String
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, shopId])
  @@index([tenantId])
  @@index([shopId])
}

model JobCard {
  id                   String           @id @default(cuid())
  tenantId             String
  shopId               String
  customerId           String?
  jobNumber            String
  publicToken          String           @unique
  customerName         String
  customerPhone        String
  customerAltPhone     String?
  deviceType           String
  deviceBrand          String
  deviceModel          String
  deviceSerial         String?
  devicePassword       String?
  customerComplaint    String
  physicalCondition    String?
  estimatedCost        Int?
  diagnosticCharge     Int?             @default(0)
  advancePaid          Int              @default(0)
  finalCost            Int?
  billType             String           @default("WITHOUT_GST")
  estimatedDelivery    DateTime?
  advancePaymentMethod String?
  advanceCashAmount    Int?
  advanceUpiAmount     Int?
  warrantyDuration     Int?             @default(0)
  consentAcknowledge   Boolean          @default(false)
  consentDataLoss      Boolean          @default(false)
  consentDiagnosticFee Boolean          @default(false)
  createdByUserId      String
  createdByName        String
  status               JobStatus        @default(RECEIVED)
  statusHistory        Json?            // Audit trail: [{ from, to, timestamp, userId, reason }]
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  customer             Party?        @relation(fields: [customerId], references: [id])
  shop                 Shop             @relation(fields: [shopId], references: [id])
  receipts            Receipt[]      @relation("JobCardReceipts")
  tenant               Tenant           @relation("TenantJobCards", fields: [tenantId], references: [id])
  parts           JobCardPart[]
  invoices             Invoice[]   @relation("JobCardInvoices")

  @@unique([shopId, jobNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([tenantId, shopId, status, createdAt])
}

model HSNCode {
  id          String          @id @default(cuid())
  code        String          @unique
  description String?
  taxRate     Float
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  hsnProducts GlobalProduct[]
}

model ProductCategory {
  id               String          @id @default(cuid())
  name             String          @unique
  createdAt        DateTime        @default(now())
  categoryProducts GlobalProduct[]
}

model GlobalProduct {
  id           String          @id @default(cuid())
  name         String
  categoryId   String
  hsnId        String
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  category     ProductCategory @relation(fields: [categoryId], references: [id])
  hsn          HSNCode         @relation(fields: [hsnId], references: [id])
  shopProducts ShopProduct[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([hsnId])
}

model ShopProduct {
  id               String            @id @default(cuid())
  tenantId         String
  shopId           String
  globalProductId  String?
  name             String
  salePrice        Int?
  costPrice        Int?              // Last Purchase Price (legacy)
  avgCost          Int?              // Weighted Average Cost (WAC) - calculated on every stock IN
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  type             ProductType
  category         String?
  isSerialized     Boolean           @default(false)
  hsnCode          String?
  gstRate          Float?            @default(0)
  reorderLevel     Int?
  reorderQty       Int?
  barcode          String?
  location         String?
  imeis            IMEI[]
  invoiceItems     InvoiceItem[]
  purchaseItems    PurchaseItem[]
  jobCardParts     JobCardPart[]
  global           GlobalProduct?    @relation(fields: [globalProductId], references: [id])
  shop             Shop              @relation(fields: [shopId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  stockCorrections StockCorrection[]
  stockEntries     StockLedger[]

  @@unique([shopId, name])
  @@index([tenantId])
  @@index([shopId])
  @@index([globalProductId])
  @@index([tenantId, shopId, isActive])
}

model IMEI {
  id                  String      @id @default(cuid())
  tenantId            String
  shopProductId       String
  imei                String
  status              IMEIStatus  @default(IN_STOCK)
  invoiceId           String?
  transferredToShopId String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  soldAt              DateTime?
  returnedAt          DateTime?
  damageNotes         String?
  lostReason          String?
  invoice             Invoice?    @relation(fields: [invoiceId], references: [id])
  product             ShopProduct @relation(fields: [shopProductId], references: [id])
  tenant              Tenant      @relation(fields: [tenantId], references: [id])
  transferredToShop   Shop?       @relation("TransferredIMEIs", fields: [transferredToShopId], references: [id])

  @@unique([tenantId, imei])
  @@index([tenantId])
  @@index([shopProductId])
  @@index([invoiceId])
  @@index([status])
  @@index([transferredToShopId])
}

model StockLedger {
  id            String         @id @default(cuid())
  tenantId      String
  shopId        String
  shopProductId String
  type          StockEntryType
  quantity      Int
  referenceType StockRefType?
  referenceId   String?
  costPerUnit   Int?
  note          String?
  createdAt     DateTime       @default(now())
  shop          Shop           @relation(fields: [shopId], references: [id])
  product       ShopProduct    @relation(fields: [shopProductId], references: [id])
  tenant        Tenant         @relation("TenantStockEntries", fields: [tenantId], references: [id])

  @@index([tenantId, shopId, createdAt])
  @@index([shopProductId, createdAt])
  @@index([tenantId, shopId, type])
  @@index([referenceType, referenceId])
}

model StockCorrection {
  id            String      @id @default(cuid())
  tenantId      String
  shopId        String
  shopProductId String
  quantity      Int
  reason        String
  note          String?
  createdBy     String?
  createdAt     DateTime    @default(now())
  shop          Shop        @relation(fields: [shopId], references: [id])
  product       ShopProduct @relation(fields: [shopProductId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, shopId])
  @@index([shopProductId])
  @@index([createdAt])
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  shopId        String
  customerId    String?
  invoiceNumber String
  invoiceDate   DateTime      @default(now())
  financialYear String?
  customerName  String
  customerPhone String?
  customerGstin String?
  customerState String?
  subTotal      Int
  gstAmount     Int
  cgst          Int?
  sgst          Int?
  igst          Int?
  totalAmount   Int
  paidAmount    Int           @default(0)
  paymentMode   PaymentMode
  cashAmount    Int?
  upiAmount     Int?
  cardAmount    Int?
  status        InvoiceStatus @default(UNPAID)
  invoiceType   InvoiceType   @default(SALES)
  isGstApplicable Boolean     @default(true)
  jobCardId     String?       // Link to JobCard for auto-generated invoices
  voidReason    String?       // Reason for void (e.g., "Job cancelled")
  voidedAt      DateTime?
  createdAt     DateTime      @default(now())
  createdBy     String?
  updatedBy     String?
  deletedAt     DateTime?
  deletedBy     String?
  imeis         IMEI[]
  customer      Party?        @relation(fields: [customerId], references: [id])
  shop          Shop          @relation(fields: [shopId], references: [id])
  tenant        Tenant        @relation("TenantInvoices", fields: [tenantId], references: [id])
  jobCard       JobCard?      @relation("JobCardInvoices", fields: [jobCardId], references: [id])
  items         InvoiceItem[]
  receipts      Receipt[]

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([tenantId, shopId, createdAt])
}

model InvoiceItem {
  id            String      @id @default(cuid())
  invoiceId     String
  shopProductId String
  quantity      Int
  rate          Int
  hsnCode       String
  gstRate       Float
  gstAmount     Int
  cgstRate      Decimal       @default(9.0)
  sgstRate      Decimal       @default(9.0)
  igstRate      Decimal       @default(0.0)
  cgstAmount    Int?
  sgstAmount    Int?
  igstAmount    Int?
  lineTotal     Int
  invoice       Invoice     @relation(fields: [invoiceId], references: [id])
  product       ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([invoiceId])
}

model JobCardPart {
  id            String      @id @default(cuid())
  jobCardId     String
  shopProductId String
  quantity      Int
  costPrice     Int?        @default(0) // Snapshot of cost at time of usage
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  jobCard       JobCard     @relation(fields: [jobCardId], references: [id])
  product       ShopProduct @relation(fields: [shopProductId], references: [id])

  @@unique([jobCardId, shopProductId])
  @@index([jobCardId])
  @@index([shopProductId])
}

model FinancialEntry {
  id            String          @id @default(cuid())
  tenantId      String
  shopId        String
  type          FinanceType
  amount        Int
  mode          PaymentMode
  referenceType FinanceRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime        @default(now())
  shop          Shop            @relation(fields: [shopId], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([shopId])
}



model Purchase {
  id               String            @id @default(cuid())
  tenantId         String
  shopId           String
  invoiceNumber    String
  globalSupplierId String?
  supplierName     String
  supplierGstin    String?           @db.VarChar(15)
  invoiceDate      DateTime          @default(now())
  dueDate          DateTime?
  subTotal         Int
  totalGst         Int
  cgst             Int?              @default(0)
  sgst             Int?              @default(0)
  igst             Int?              @default(0)
  grandTotal       Int
  paidAmount       Int               @default(0)
  paymentMethod    PaymentMode
  paymentReference String?
  cashAmount       Int?
  upiAmount        Int?
  purchaseType     String            @default("Goods")
  taxInclusive     Boolean           @default(false)
  isLegacyGstApproximation Boolean  @default(false)
  gstApproximationReason   String?
  verifiedByUserId         String?
  verifiedAt               DateTime?
  status           PurchaseStatus    @default(DRAFT)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String?
  party            Party?         @relation("PartyToPurchases", fields: [globalSupplierId], references: [id])
  shop             Shop           @relation(fields: [shopId], references: [id])
  tenant           Tenant            @relation("TenantPurchases", fields: [tenantId], references: [id])
  items            PurchaseItem[]
  payments         SupplierPayment[]
  supplierAdvances AdvanceApplication[]

  @@unique([shopId, invoiceNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([globalSupplierId])
}

model PurchaseItem {
  id            String       @id @default(cuid())
  purchaseId    String
  shopProductId String?
  description   String
  hsnSac        String?
  quantity      Int
  purchasePrice Int
  gstRate       Float        @default(0)
  cgstRate      Decimal       @default(9.0)
  sgstRate      Decimal       @default(9.0)
  igstRate      Decimal       @default(0.0)
  taxAmount     Int          @default(0)
  cgstAmount    Int?
  sgstAmount    Int?
  igstAmount    Int?
  totalAmount   Int
  createdAt     DateTime     @default(now())
  purchase      Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product       ShopProduct? @relation(fields: [shopProductId], references: [id])

  @@index([purchaseId])
  @@index([shopProductId])
}

model SupplierPayment {
  id               String      @id @default(cuid())
  tenantId         String
  shopId           String
  purchaseId       String?
  globalSupplierId String?
  amount           Int
  paymentMethod    PaymentMode
  paymentReference String?
  paymentDate      DateTime    @default(now())
  notes            String?
  createdAt        DateTime    @default(now())
  createdBy        String?
  purchase         Purchase?   @relation(fields: [purchaseId], references: [id])
  tenant           Tenant      @relation("TenantSupplierPayments", fields: [tenantId], references: [id])
  party            Party?      @relation(fields: [globalSupplierId], references: [id])


  @@index([tenantId])
  @@index([shopId])
  @@index([purchaseId])
}

model Receipt {
  id              String        @id @default(cuid())
  tenantId        String
  shopId          String
  receiptId       String        @unique
  printNumber     String
  receiptType     ReceiptType
  amount          Int
  paymentMethod   PaymentMode
  transactionRef  String?
  customerId      String?
  customerName    String
  customerPhone   String?
  linkedInvoiceId String?
  linkedJobCardId String?
  narration       String?
  status          ReceiptStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?
  party           Party?        @relation(fields: [customerId], references: [id])
  invoice         Invoice?      @relation(fields: [linkedInvoiceId], references: [id])
  jobCard         JobCard?      @relation("JobCardReceipts", fields: [linkedJobCardId], references: [id])
  shop            Shop          @relation(fields: [shopId], references: [id])
  tenant          Tenant        @relation("TenantReceipts", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([linkedInvoiceId])
  @@index([linkedJobCardId])
}

model PaymentVoucher {
  id               String        @id @default(cuid())
  tenantId         String
  shopId           String
  voucherId        String        @unique
  voucherType      VoucherType
  voucherSubType   VoucherSubType?
  date             DateTime      @default(now())
  amount           Int
  paymentMethod    PaymentMode
  transactionRef   String?
  narration        String?
  globalSupplierId String?
  expenseCategory  String?
  linkedPurchaseId String?
  status           VoucherStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  createdBy        String?
  party            Party?        @relation(fields: [globalSupplierId], references: [id])
  shop             Shop          @relation(fields: [shopId], references: [id])
  tenant           Tenant        @relation("TenantPaymentVouchers", fields: [tenantId], references: [id])
  advanceApplications AdvanceApplication[]

  @@index([tenantId])
  @@index([shopId])
}

model AdvanceApplication {
  id                String          @id @default(cuid())
  advanceVoucherId  String
  purchaseId        String
  appliedAmount     Int
  appliedAt         DateTime        @default(now())
  advanceVoucher    PaymentVoucher  @relation(fields: [advanceVoucherId], references: [id])
  purchase          Purchase        @relation(fields: [purchaseId], references: [id])

  @@unique([advanceVoucherId, purchaseId])
  @@index([advanceVoucherId])
  @@index([purchaseId])
}

model Quotation {
  id              String          @id @default(cuid())
  tenantId        String
  shopId          String
  quotationNumber String
  customerId      String?
  customerName    String
  quotationDate   DateTime        @default(now())
  totalAmount     Int             @default(0)
  notes           String?
  status          QuotationStatus @default(DRAFT)
  validityDays    Int             @default(30)
  expiryDate      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String?
  party           Party?          @relation(fields: [customerId], references: [id])
  shop            Shop            @relation(fields: [shopId], references: [id])
  tenant          Tenant          @relation("TenantQuotations", fields: [tenantId], references: [id])
  items           QuotationItem[]

  @@unique([shopId, quotationNumber])
  @@index([tenantId])
  @@index([shopId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Int
  price       Int
  totalAmount Int
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model PurchaseOrder {
  id                   String              @id @default(cuid())
  tenantId             String
  shopId               String
  poNumber             String
  globalSupplierId     String?
  supplierName         String
  party                Party?              @relation(fields: [globalSupplierId], references: [id])
  orderDate            DateTime            @default(now())
  expectedDelivery     DateTime?
  totalEstimatedAmount Int                 @default(0)
  notes                String?
  status               POStatus            @default(DRAFT)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdBy            String?
  shop                 Shop                @relation(fields: [shopId], references: [id])
  tenant               Tenant              @relation("TenantPurchaseOrders", fields: [tenantId], references: [id])
  items                PurchaseOrderItem[]

  @@unique([shopId, poNumber])
  @@index([tenantId])
  @@index([shopId])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  poId             String
  globalProductId  String?
  description      String
  quantity         Int
  estimatedPrice   Int?
  receivedQuantity Int           @default(0)
  po               PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}



model WhatsAppPhoneNumberModule {
