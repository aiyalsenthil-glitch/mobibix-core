// ✅ NEW: IMEI Status Enum
// Tracks lifecycle of serialized product units (mobiles, laptops, etc.)
enum IMEIStatus {
  IN_STOCK // Available for sale
  SOLD // Sold to customer (linked to invoice)
  RETURNED // Returned from customer (refund/exchange)
  DAMAGED // Damaged/non-functional, can't sell
  TRANSFERRED // Transferred to another shop
  LOST // Lost/stolen/missing
}

// ============= DOCUMENT NUMBERING SYSTEM =============

// Document types that support automatic numbering
enum DocumentType {
  SALES_INVOICE
  PURCHASE_INVOICE
  JOB_CARD
  RECEIPT
  QUOTATION
  PURCHASE_ORDER
  PAYMENT_VOUCHER
}

// Financial year format options
enum YearFormat {
  FY // 2526 (Financial Year: April 2025 - March 2026)
  YYYY // 20252026 (Full 4-digit years)
  YY // 26 (Ending year only, 2-digit)
  NONE // No year in number
}

// When to reset the sequence number
enum ResetPolicy {
  NEVER // Never reset (continuous numbering)
  YEARLY // Reset on financial year change
  MONTHLY // Reset every month
}

// ============= CRM ENUMS =============

// Type of follow-up action
enum FollowUpType {
  CALL // Phone call
  WHATSAPP // WhatsApp message
  VISIT // In-person visit
  EMAIL // Email
  SMS // SMS message
}

// Purpose of the follow-up
enum FollowUpPurpose {
  SALE // Prospecting/sales
  SERVICE // Service/repair related
  PAYMENT // Payment collection
  FEEDBACK // Customer feedback/survey
  RETENTION // Loyalty/retention
  OTHER // General follow-up
}

// Status of the follow-up
enum FollowUpStatus {
  PENDING // Not yet done
  DONE // Completed
  CANCELLED // Cancelled/no action needed
}

// When to trigger the reminder
enum ReminderTriggerType {
  DATE // Fixed date (e.g., "2026-02-14")
  AFTER_INVOICE // N days after invoice date
  AFTER_JOB // N days after job card completion
}

// Channel for sending reminder
enum ReminderChannel {
  WHATSAPP // Send via WhatsApp
  IN_APP // In-app notification
  EMAIL // Email notification
  SMS // SMS notification
}

// Status of the reminder
enum ReminderStatus {
  SCHEDULED // Waiting to be sent
  SENT // Successfully sent
  FAILED // Failed to send
  SKIPPED // Manually skipped
}

// Source of loyalty points
enum LoyaltySource {
  INVOICE // Points from purchase
  MANUAL // Admin added manually
  PROMOTION // Promotional campaign
  REFERRAL // Referral bonus
  REDEMPTION // Points redeemed (negative)
}

// Severity level of alert
enum AlertSeverity {
  INFO // Informational
  WARNING // Warning (action recommended)
  CRITICAL // Critical (needs immediate attention)
}

// Source/reason for the alert
enum AlertSource {
  OVERDUE // Payment overdue
  HIGH_VALUE // High-value customer activity
  REPEAT_REPAIR // Customer with repeat repairs (may indicate issue)
  CHURN_RISK // Customer not active recently
  INACTIVE // Customer marked inactive
  CUSTOM // Custom alert from staff
}
