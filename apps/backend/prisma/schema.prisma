generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BillingType {
  MANUAL
  AUTOPAY
}

enum AutopayStatus {
  ACTIVE
  HALTED
  CANCELLED
  PAST_DUE
}

enum DeletionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum TenantStatus {
  ACTIVE
  PENDING_DELETION
  SUSPENDED
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

model Tenant {
  lastLoginAt DateTime?

  id                 String            @id @default(cuid())
  name               String
  legalName          String?
  tenantType         String
  code               String            @unique
  contactPhone       String?
  contactEmail       String?
  website            String?
  logoUrl            String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  pincode            String?
  country            String            @default("India")
  stateCode          String? // ISO-3166-2:IN (e.g. TN, KA, MH)
  gstNumber          String?
  taxId              String?
  businessType       String?
  businessCategoryId String?
  businessCategory   BusinessCategory? @relation("TenantBusinessCategory", fields: [businessCategoryId], references: [id])
  currency           String            @default("INR")
  timezone           String            @default("Asia/Kolkata")
  taxSystem          String            @default("GST")
  createdAt          DateTime          @default(now())
  createdBy          String?
  updatedAt          DateTime          @updatedAt
  updatedBy          String?
  deletedAt          DateTime?
  deletedBy          String?

  kioskToken               String?                 @unique
  enabledModules           ModuleType[] // Gates what permissions a tenant can assign to roles
  maxMembers               Int                     @default(50)
  whatsappEnabled          Boolean                 @default(true)
  whatsappCrmEnabled       Boolean                 @default(false)
  whatsappPhoneNumberId    String?
  whatsappBusinessId       String?
  whatsappWabaId           String?
  whatsappReminderNumberId String? // Added for Phase 1
  whatsappReminderNumber   WhatsAppNumber?         @relation("TenantReminderNumber", fields: [whatsappReminderNumberId], references: [id])
  auditLogs                AuditLog[]
  parties                  Party[]                 @relation("TenantParties")
  customerAlerts           CustomerAlert[]         @relation("TenantCustomerAlerts")
  customerFollowUps        CustomerFollowUp[]      @relation("TenantCustomerFollowUps")
  customerReminders        CustomerReminder[]      @relation("TenantCustomerReminders")
  financialEntries         FinancialEntry[]
  imeis                    IMEI[]
  invoices                 Invoice[]               @relation("TenantInvoices")
  jobCards                 JobCard[]               @relation("TenantJobCards")
  ledgerAccounts           LedgerAccount[]
  ledgerCustomers          LedgerCustomer[]
  ledgerPayments           LedgerPayment[]
  supplierPayments         SupplierPayment[]       @relation("TenantSupplierPayments")
  loyaltyConfigs           LoyaltyConfig[]
  loyaltyTransactions      LoyaltyTransaction[]
  members                  Member[]                @relation("TenantMembers")
  payments                 Payment[]
  subscriptionInvoices     SubscriptionInvoice[]   @relation("TenantToSubscriptionInvoice")
  paymentVouchers          PaymentVoucher[]        @relation("TenantPaymentVouchers")
  purchases                Purchase[]              @relation("TenantPurchases")
  purchaseOrders           PurchaseOrder[]         @relation("TenantPurchaseOrders")
  quotations               Quotation[]             @relation("TenantQuotations")
  creditNotes              CreditNote[]            @relation("TenantCreditNotes")
  receipts                 Receipt[]               @relation("TenantReceipts")
  shops                    Shop[]
  shopProducts             ShopProduct[]
  shopStaffs               ShopStaff[]
  stockCorrections         StockCorrection[]
  stockEntries             StockLedger[]           @relation("TenantStockEntries")
  subscription             TenantSubscription[]
  users                    User[]
  userTenants              UserTenant[]
  whatsAppCampaigns        WhatsAppCampaign[]
  whatsAppUsage            WhatsAppDailyUsage[]
  usageSnapshots           UsageSnapshot[]
  featureFlags             FeatureFlag[]           @relation("TenantFeatureFlags")
  emailLogs                EmailLog[]
  roles                    Role[]
  approvalRequests         ApprovalRequest[]
  distributorLinks         DistributorTenantLink[]
  b2bPurchaseOrders        B2BPurchaseOrder[]
  invites                  StaffInvite[]

  // 🔐 Compliance & Legal Tracking
  termsAcceptedAt        DateTime?
  privacyAcceptedAt      DateTime?
  marketingConsent       Boolean           @default(false)
  acceptedPolicyVersion  String?
  consentIpAddress       String?
  consentUserAgent       String?
  domain                 String?
  deletionRequestPending Boolean           @default(false)
  deletionScheduledAt    DateTime?
  status                 TenantStatus      @default(ACTIVE)
  deletionRequests       DeletionRequest[] @relation("TenantDeletionRequests")
  notificationLogs       NotificationLog[]
  contacts               Contact[]

  partnerId          String?
  partner            Partner?            @relation(fields: [partnerId], references: [id])
  promoCodeId        String?
  appliedPromoCode   PromoCode?          @relation(fields: [promoCodeId], references: [id])
  promoUsages        PromoUsage[]
  aiUsageLogs        AiUsageLog[]
  loyaltyAdjustments LoyaltyAdjustment[]
  billingEventLogs   BillingEventLog[]
}

model DeletionRequest {
  id          String         @id @default(uuid())
  tenantId    String
  requestedBy String
  requestedAt DateTime       @default(now())
  reason      String?
  status      DeletionStatus @default(PENDING)
  adminNotes  String?
  resolvedAt  DateTime?

  // Compliance Snapshot Fields
  originalEmail     String?
  originalLegalName String?
  originalPhone     String?
  originalGstNumber String?
  isHardDeleted     Boolean @default(false)

  tenant Tenant @relation("TenantDeletionRequests", fields: [tenantId], references: [id])
}

model NotificationLog {
  id          String              @id @default(cuid())
  tenantId    String
  userId      String?
  eventId     String
  channel     NotificationChannel
  recipient   String
  status      NotificationStatus  @default(PENDING)
  payload     Json?
  errorReason String?
  retryCount  Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sentAt      DateTime?
  readAt      DateTime? // null = unread, set = read — powers in-app bell badge
  title       String? // Short title for bell display (e.g. "🎁 Promo Activated!")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([eventId])
  @@index([createdAt])
  @@index([tenantId, channel, readAt]) // unread bell query optimization
  @@map("mb_notification_log")
}

model BusinessCategory {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  isActive     Boolean  @default(true)
  isComingSoon Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants Tenant[] @relation("TenantBusinessCategory")

  @@index([isActive, sortOrder])
}

model UserTenant {
  id            String    @id @default(cuid())
  userId        String
  tenantId      String
  role          UserRole  @default(STAFF) // LEGACY: Kept for Phase 2 Migration
  isSystemOwner Boolean   @default(false)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model User {
  id           String    @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid  String    @unique
  email        String?
  fullName     String?
  avatar       String?
  role         UserRole
  tenantId     String?
  permissions  Json?
  createdAt    DateTime  @default(now())
  createdBy    String?
  updatedAt    DateTime  @updatedAt
  updatedBy    String?
  deletedAt    DateTime?
  deletedBy    String?
  tokenVersion Int       @default(0)

  phone              String?
  welcomeEmailSent   Boolean            @default(false)
  marketingConsent   Boolean            @default(false)
  privacyAcceptedAt  DateTime?
  auditLogs          AuditLog[]
  assignedFollowUps  CustomerFollowUp[]
  platformAuditLogs  PlatformAuditLog[]
  shopStaffs         ShopStaff[]
  ledgerPayments     LedgerPayment[]
  tenant             Tenant?            @relation(fields: [tenantId], references: [id])
  userTenants        UserTenant[]
  assignedJobs       JobCard[]          @relation("JobCardAssignment")
  refreshTokens      RefreshToken[]
  emailLogs          EmailLog[]
  requestedApprovals ApprovalRequest[]  @relation("RequestedApprovals")
  resolvedApprovals  ApprovalRequest[]  @relation("ResolvedApprovals")
  promoUsages        PromoUsage[]
  adminUser          AdminUser?
  notificationLogs   NotificationLog[]

  @@index([REMOVED_AUTH_PROVIDERUid])
  @@index([REMOVED_AUTH_PROVIDERUid, deletedAt])
  @@index([email])
  @@index([tenantId, deletedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Contact {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  phone           String
  normalizedPhone String
  email           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parties Party[]
  members Member[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, normalizedPhone])
  @@index([tenantId])
  @@map("mb_contact")
}

model Member {
  id                String              @id @default(uuid())
  tenantId          String
  contactId         String? // Link to Unified Contact
  fullName          String
  phone             String
  gender            Gender
  membershipPlanId  String
  membershipStartAt DateTime
  membershipEndAt   DateTime
  feeAmount         Int
  paymentStatus     MemberPaymentStatus
  heightCm          Float
  weightKg          Float
  fitnessGoal       FitnessGoal
  createdAt         DateTime            @default(now())
  createdBy         String?
  updatedAt         DateTime            @updatedAt
  updatedBy         String?
  deletedAt         DateTime?
  deletedBy         String?

  paidAmount          Int             @default(0)
  monthlyFee          Int
  paymentDueDate      DateTime
  paymentReminderSent Boolean         @default(false)
  isActive            Boolean         @default(true)
  photoUrl            String?
  welcomeMessageSent  Boolean         @default(false)
  hasCoaching         Boolean         @default(false)
  customerId          String?
  attendances         GymAttendance[]
  gymMemberships      GymMembership[]
  customer            Party?          @relation(fields: [customerId], references: [id])
  contact             Contact?        @relation(fields: [contactId], references: [id])
  tenant              Tenant          @relation("TenantMembers", fields: [tenantId], references: [id])
  payments            MemberPayment[]

  @@unique([id, tenantId])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, deletedAt]) // Soft Delete Optimization
  @@index([fullName]) // Search Optimization
  @@map("gp_member")
}

model Party {
  id                  String       @id @default(cuid())
  tenantId            String
  contactId           String? // Link to Unified Contact
  name                String
  phone               String
  email               String?
  state               String?
  gstNumber           String?
  businessType        BusinessType @default(B2C)
  partyType           PartyType    @default(CUSTOMER)
  isActive            Boolean      @default(true)
  altPhone            String?
  address             String?
  defaultPaymentTerms String?
  defaultCreditLimit  Int?
  defaultCurrency     String       @default("INR")
  tags                String[]     @default([])
  createdBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?
  deletedBy           String?

  // Global & Atomic Hardening
  normalizedPhone    String  @default("") // Forced mandatory for identity hardening
  countryCode        String  @default("IN")
  isoStateCode       String? // ISO 3166-2 state code (e.g., "TN")
  currentOutstanding Int     @default(0) // Derrived atomic balance
  mergedIntoId       String? // ID of the target party if merged

  supplierProfile SupplierProfile?

  tenant              Tenant               @relation("TenantParties", fields: [tenantId], references: [id])
  contact             Contact?             @relation(fields: [contactId], references: [id])
  alerts              CustomerAlert[]
  followUps           CustomerFollowUp[]
  reminders           CustomerReminder[]
  invoices            Invoice[]
  jobCards            JobCard[]
  loyaltyTransactions LoyaltyTransaction[]
  members             Member[]
  purchases           Purchase[]           @relation("PartyToPurchases")
  supplierPayments    SupplierPayment[]
  receipts            Receipt[]
  quotations          Quotation[]
  purchaseOrders      PurchaseOrder[]
  paymentVouchers     PaymentVoucher[]
  whatsAppLogs        WhatsAppLog[]
  emailLogs           EmailLog[]
  ledgerCustomers     LedgerCustomer[]

  // Merge & Loyalty Audit Relations
  mergedInto         Party?              @relation("PartyMerge", fields: [mergedIntoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mergesFrom         Party[]             @relation("PartyMerge")
  loyaltyAdjustments LoyaltyAdjustment[]

  customerCreditNotes CreditNote[] @relation("CustomerCreditNotes")
  supplierCreditNotes CreditNote[] @relation("SupplierCreditNotes")

  @@unique([tenantId, phone]) // Legacy unique constraint
  @@unique([tenantId, normalizedPhone]) // Global identity constraint
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([name])
  @@map("mb_party")
}

model LoyaltyAdjustment {
  id           String   @id @default(cuid())
  tenantId     String
  partyId      String
  beforePoints Int
  afterPoints  Int
  delta        Int
  reason       String
  adjustedBy   String // UserId
  createdAt    DateTime @default(now())

  party  Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([partyId])
  @@index([createdAt])
  @@map("mb_loyalty_adjustment")
}

model SupplierProfile {
  id                String  @id @default(cuid())
  partyId           String  @unique
  category          String? // Tier-1, Tier-2, etc.
  riskFlag          Boolean @default(false)
  rating            Float   @default(0.0)
  paymentDueDays    Int     @default(30)
  creditLimit       Int? // in Paisa
  preferredCurrency String  @default("INR")

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@map("mb_supplier_profile")
}

model CustomerFollowUp {
  id               String          @id @default(cuid())
  tenantId         String
  customerId       String
  shopId           String?
  type             FollowUpType
  purpose          FollowUpPurpose
  note             String?
  followUpAt       DateTime
  status           FollowUpStatus  @default(PENDING)
  assignedToUserId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  assignedToUser   User?           @relation(fields: [assignedToUserId], references: [id])
  customer         Party           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop             Shop?           @relation(fields: [shopId], references: [id])
  tenant           Tenant          @relation("TenantCustomerFollowUps", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([shopId])
  @@index([assignedToUserId])
  @@index([followUpAt])
  @@index([status])
  @@index([tenantId, assignedToUserId, status, followUpAt])
  @@map("mb_customer_follow_up")
}

model CustomerReminder {
  id            String              @id @default(cuid())
  tenantId      String
  customerId    String
  triggerType   ReminderTriggerType
  triggerValue  String
  channel       ReminderChannel
  templateKey   String
  status        ReminderStatus      @default(SCHEDULED)
  scheduledAt   DateTime?
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  customer      Party               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation("TenantCustomerReminders", fields: [tenantId], references: [id])

  // 🔥 Indexes for common queries
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([status, channel, scheduledAt]) // Optimized for cron reminder fetch
  @@index([tenantId, status, scheduledAt]) // Composite for fetching pending reminders by time
  @@map("mb_customer_reminder")
}

model LoyaltyConfig {
  id       String  @id @default(cuid())
  tenantId String
  shopId   String? @unique

  // Feature Toggle
  isEnabled Boolean @default(false)

  // Earning Rules (amounts in paise)
  earnAmountPerPoint Int @default(10000) // ₹100 = 1 point
  pointsPerEarnUnit  Int @default(1)

  // Redemption Rules
  pointValueInRupees Float @default(1.0) // 1 point = ₹1
  maxRedeemPercent   Int   @default(50) // Max 50% of invoice

  // Category Restrictions
  allowOnRepairs     Boolean @default(true)
  allowOnAccessories Boolean @default(true)
  allowOnServices    Boolean @default(false)

  // Expiry
  expiryDays Int? // null = never expires

  // Admin Controls
  allowManualAdjustment Boolean @default(false)
  minInvoiceForEarn     Int? // Minimum invoice amount (paise)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shop   Shop?  @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([shopId])
  @@map("mb_loyalty_config")
}

model LoyaltyTransaction {
  id         String  @id @default(cuid())
  tenantId   String
  shopId     String?
  customerId String

  // Transaction Details
  points Int // Positive = earn, Negative = redeem/expire/reverse
  type   LoyaltyTransactionType
  source LoyaltySource

  // Audit Trail
  invoiceId   String? // Link to invoice (for earn/redeem)
  reversalOf  String? // Points to original transaction ID if reversal
  referenceId String? // Added for tracking related transactions (e.g. expiry source)

  // Metadata
  note      String?
  createdBy String? // User ID for manual adjustments
  createdAt DateTime @default(now())

  // Relations
  customer Party  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  shop     Shop?  @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([reversalOf])
  @@index([referenceId])
  @@index([createdAt])
  @@map("mb_loyalty_transaction")
}

model CustomerAlert {
  id         String        @id @default(cuid())
  tenantId   String
  customerId String
  severity   AlertSeverity
  message    String
  source     AlertSource
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  customer   Party         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant     Tenant        @relation("TenantCustomerAlerts", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
  @@map("mb_customer_alert")
}

model LedgerCustomer {
  id         String          @id @default(cuid())
  tenantId   String
  customerId String? // Link to central Party model
  name       String
  phone      String
  address    String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  ledgers    LedgerAccount[]
  payments   LedgerPayment[]
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  customer   Party?          @relation(fields: [customerId], references: [id])

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([customerId])
  @@map("lg_ledger_customer")
}

model LedgerAccount {
  id                String                @id @default(cuid())
  tenantId          String
  customerId        String
  principalAmount   Int
  expectedTotal     Int
  installmentType   LedgerInstallmentType
  installmentAmount Int
  totalPeriods      Int
  startDate         DateTime
  status            LedgerStatus          @default(ACTIVE)
  createdAt         DateTime              @default(now())
  customer          LedgerCustomer        @relation(fields: [customerId], references: [id])
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  collections       LedgerCollection[]
  payments          LedgerPayment[]

  @@index([tenantId])
  @@index([customerId])
  @@map("lg_ledger_account")
}

model LedgerCollection {
  id         String          @id @default(cuid())
  tenantId   String
  ledgerId   String
  periodNo   Int
  dueDate    DateTime
  amount     Int
  paidAmount Int             @default(0)
  paid       Boolean         @default(false)
  paidAt     DateTime?
  createdAt  DateTime        @default(now())
  ledger     LedgerAccount   @relation(fields: [ledgerId], references: [id])
  payments   LedgerPayment[]

  @@index([tenantId])
  @@index([ledgerId])
  @@map("lg_ledger_collection")
}

model LedgerPayment {
  id              String              @id @default(cuid())
  tenantId        String
  ledgerId        String
  customerId      String
  collectionId    String
  collectedBy     String
  amount          Int
  method          LedgerPaymentMethod
  note            String?
  collectedAt     DateTime            @default(now())
  createdAt       DateTime            @default(now())
  ledger          LedgerAccount       @relation(fields: [ledgerId], references: [id])
  customer        LedgerCustomer      @relation(fields: [customerId], references: [id])
  collection      LedgerCollection    @relation(fields: [collectionId], references: [id])
  collectedByUser User                @relation(fields: [collectedBy], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([ledgerId])
  @@index([customerId])
  @@index([collectionId])
  @@index([collectedBy])
  @@map("lg_ledger_payment")
}

model StaffInvite {
  id          String            @id @default(cuid())
  email       String
  tenantId    String
  status      StaffInviteStatus @default(PENDING)
  inviteToken String?           @unique @default(cuid())
  role        UserRole          @default(STAFF) // LEGACY: Kept for Phase 2 Migration
  roleId      String? // Made optional for Phase 1/2 Migration
  name        String?
  phone       String?
  shopIds     String[]          @default([])
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime?         @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  dynamicRole Role?  @relation(fields: [roleId], references: [id])

  @@unique([tenantId, email, status], name: "invite_composite_key") // Allow re-inviting even if previous exists if its REJECTED/EXPIRED
  @@index([email, status, deletedAt])
  @@index([email])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, deletedAt])
}

enum StaffInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model MemberPayment {
  id           String              @id @default(cuid())
  tenantId     String
  memberId     String
  amount       Int
  status       MemberPaymentStatus
  method       String?
  reference    String?
  gstRate      Float?
  gstAmount    Float?
  total        Int?
  createdAt    DateTime            @default(now())
  durationDays Int?
  member       Member              @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
  @@map("gp_member_payment")
}

model Plan {
  id           String     @id @default(uuid())
  code         String     @unique
  name         String     @unique
  level        Int
  module       ModuleType
  isActive     Boolean    @default(true)
  isPublic     Boolean    @default(true)
  isAddon      Boolean    @default(false)
  tagline      String?
  description  String?
  featuresJson Json? // For detailed feature list/UI display (frontend only)
  meta         Json? // For add-on config (e.g. { "quota": { "utility": 500 } })

  // Plan Limits (moved from hardcoded PLAN_LIMITS)
  maxStaff               Int? // null = unlimited (applies to all modules)
  maxMembers             Int? // null = unlimited (GYM only - Mobibix has unlimited Parties)
  maxShops               Int? // null = unlimited (Mobile Shop)
  whatsappUtilityQuota   Int  @default(0) // Monthly quota (all modules)
  whatsappMarketingQuota Int  @default(0) // Monthly quota (all modules)
  analyticsHistoryDays   Int  @default(30) // Days of analytics history (all modules)
  maxAiTokens            Int  @default(100) // AI tokens per billing cycle

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planFeatures       PlanFeature[]
  subscriptions      TenantSubscription[]
  planPrices         PlanPrice[]
  addonSubscriptions SubscriptionAddon[]  @relation("AddonPlans") // When this plan is used as an add-on
}

model PlanPrice {
