model EmailLog {
  id       String @id @default(cuid())
  tenantId String

  // Recipient Details
  recipientType  EmailRecipientType
  recipientEmail String
  staffId        String? // Optional: Link to User if Staff
  customerId     String? // Optional: Link to Party if Customer

  // Email Details
  emailType   String // e.g. "TRIAL_EXPIRING", "INVOICE_GENERATED"
  referenceId String // Composite uniqueness key (e.g. InvoiceID, MemberID + Date)
  subject     String
  body        String? // Optional: Store rendered HTML (debug only?) or just metadata

  // Context
  module ModuleType // GYM | MOBILE_SHOP

  // Status & Metadata
  status     EmailStatus @default(PENDING)
  sentAt     DateTime?
  error      String?
  retryCount Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations (Optional but helpful for data integrity)
  staff    User?  @relation(fields: [staffId], references: [id])
  customer Party? @relation(fields: [customerId], references: [id])

  // 🔥 IDEMPOTENCY KEY
  @@unique([tenantId, recipientType, emailType, referenceId, module], name: "idempotency_key")
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// ENTERPRISE ROLE & PERMISSION ARCHITECTURE
// ============================================================================

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum RoleCategory {
  SYSTEM_TEMPLATE // e.g. "Manager"
  CUSTOM // Built from scratch
  CLONE // Customized copy of a template
}

model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  category    RoleCategory @default(CUSTOM)
  tenantId    String? // System template if null
  isSystem    Boolean      @default(false)
  isRoot      Boolean      @default(false)

  deletedAt DateTime?

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  rolePermissions RolePermission[]
  shopStaff       ShopStaff[]
  invites         StaffInvite[]
  versions        RoleVersion[]

  @@unique([tenantId, name])
}

model RoleVersion {
  id        String   @id @default(cuid())
  roleId    String
  version   Int      @default(1)
  snapshot  Json
  createdAt DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model Resource {
  id          String       @id @default(cuid())
  moduleType  ModuleType
  name        String
  description String?
  permissions Permission[]

  @@unique([moduleType, name])
}

model Permission {
  id             String  @id @default(cuid())
  resourceId     String
  action         String
  description    String?
  approvalPolicy Json?

  resource        Resource         @relation(fields: [resourceId], references: [id])
  rolePermissions RolePermission[]

  @@unique([resourceId, action])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalRequest {
  id          String @id @default(cuid())
  tenantId    String
  shopId      String
  requestedBy String

  actionType     String
  entityId       String?
  structuredData Json

  status       ApprovalStatus @default(PENDING)
  resolvedBy   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ownerComment String?
  deletedAt    DateTime?
  deletedBy    String?

  requester User   @relation("RequestedApprovals", fields: [requestedBy], references: [id])
  resolver  User?  @relation("ResolvedApprovals", fields: [resolvedBy], references: [id])
  shop      Shop   @relation(fields: [shopId], references: [id])
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, shopId])
  @@index([status])
  @@index([tenantId, deletedAt])
}

// ─── CORS Management ─────────────────────────────────────────────────────────
model CorsAllowedOrigin {
  id        String   @id @default(cuid())
  origin    String   @unique
  label     String? // Human-readable label e.g. "Gympilot Production"
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isEnabled])
}

// ─── B2B Wholesale Portal ───────────────────────────────────────────────────

model Distributor {
  id           String  @id @default(cuid())
  name         String
  gstNumber    String?
  contactPhone String?
  address      String?
  city         String?
  state        String?

  // Relations
  catalogs       WholesaleCatalog[]
  networkLinks   DistributorTenantLink[]
  purchaseOrders B2BPurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mb_distributor")
}

model DistributorTenantLink {
  id            String     @id @default(cuid())
  tenantId      String
  distributorId String
  status        LinkStatus @default(PENDING)

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  distributor Distributor @relation(fields: [distributorId], references: [id])

  createdAt DateTime @default(now())

  @@unique([tenantId, distributorId])
  @@map("mb_distributor_tenant_link")
}

enum LinkStatus {
  PENDING
  APPROVED
  REJECTED
}

model WholesaleCatalog {
  id             String @id @default(cuid())
  distributorId  String
  sku            String
  productName    String
  category       String
  wholesalePrice Float
  moq            Int    @default(1)
  stockAvailable Int    @default(0)

  distributor Distributor    @relation(fields: [distributorId], references: [id])
  orderItems  B2BOrderItem[]

  updatedAt DateTime @updatedAt

  @@map("mb_wholesale_catalog")
}

model B2BPurchaseOrder {
  id            String      @id @default(cuid())
  poNumber      String      @unique
  tenantId      String
  distributorId String
  status        B2BPOStatus @default(SUBMITTED)
  totalAmount   Float

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  distributor Distributor    @relation(fields: [distributorId], references: [id])
  items       B2BOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("mb_b2_b_purchase_order")
}

model B2BOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  catalogItemId   String
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  purchaseOrder B2BPurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  catalogItem   WholesaleCatalog @relation(fields: [catalogItemId], references: [id])

  @@map("mb_b2_b_order_item")
}

enum B2BPOStatus {
  SUBMITTED
  ACCEPTED
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Partner & Promo System ────────────────────────────────────────────────

model Partner {
  id                   String        @id @default(cuid())
  businessName         String
  contactPerson        String
  email                String        @unique
  phone                String
  partnerType          PartnerType
  region               String?
  status               PartnerStatus @default(PENDING)
  referralCode         String        @unique
  commissionPercentage Float         @default(0)
  totalEarned          Float         @default(0)
  totalPaid            Float         @default(0)
  passwordHash         String

  // Relations
  referredTenants Tenant[]
  promoCodes      PromoCode[]
  referrals       PartnerReferral[]

  approvedAt        DateTime?
  approvedByAdminId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum PartnerType {
  DISTRIBUTOR
  ACADEMY
  HARDWARE
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model PromoCode {
  id                 String        @id @default(cuid())
  code               String        @unique
  description        String?
  type               PromoCodeType
  durationDays       Int
  discountPercentage Float?
  maxUses            Int           @default(500)
  usedCount          Int           @default(0)
  expiresAt          DateTime?
  isActive           Boolean       @default(true)

  // Relations
  partnerId     String?
  partner       Partner? @relation(fields: [partnerId], references: [id])
  usedByTenants Tenant[]

  createdByAdminId String?
  createdAt        DateTime     @default(now())
  usages           PromoUsage[]
}

enum PromoCodeType {
  FREE_TRIAL
  DISCOUNT
}

model PartnerReferral {
  id                   String         @id @default(cuid())
  partnerId            String
  tenantId             String
  subscriptionPlan     String
  subscriptionAmount   Float
  commissionPercentage Float
  commissionAmount     Float
  status               ReferralStatus @default(PENDING)

  partner Partner @relation(fields: [partnerId], references: [id])

  confirmedAt DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("mb_partner_referral")
}

enum ReferralStatus {
  PENDING
  CONFIRMED
  PAID
}

enum AdminRole {
  SUPER_ADMIN
  FINANCE_ADMIN
  SUPPORT_ADMIN
  PRODUCT_ADMIN
}

model AdminUser {
  id           String      @id @default(cuid())
  userId       String      @unique
  role         AdminRole   @default(PRODUCT_ADMIN)
  productScope ModuleType?
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id])

  @@index([role])
}

model AiUsageLog {
  id               String     @id @default(cuid())
  tenantId         String
  module           ModuleType
  feature          String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costUsd          Float
  createdAt        DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([module, createdAt])
  @@map("ai_usage_logs")
}

model PromoUsage {
  id        String   @id @default(cuid())
  promoId   String
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  promo  PromoCode @relation(fields: [promoId], references: [id])
  user   User      @relation(fields: [userId], references: [id])
  tenant Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([promoId, tenantId]) // Enforce one use per tenant
  @@index([promoId])
  @@index([userId])
  @@index([tenantId])
  @@map("promo_usages")
}

model BillingEventLog {
  id                  String   @id @default(cuid())
  tenantId            String
  eventType           String // e.g., 'payment.refunded', 'payment.dispute.created'
  providerReferenceId String? // Razorpay payment/subscription/refund ID
  statusBefore        String?
  statusAfter         String?
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CountryConfig {
  id          String   @id @default(cuid())
  code        String   @unique // ISO 2-letter (IN, AE, US)
  name        String
  currency    String
  timezone    String
  phonePrefix String
  taxSystem   String   @default("GST")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

enum WaitlistSource {
  FEATURES_PAGE
  APP_DASHBOARD
  OTHER
}

model WaitlistLead {
  id        String         @id @default(cuid())
  phone     String         @unique // Shop WhatsApp Number
  email     String?
  source    WaitlistSource @default(FEATURES_PAGE)
  status    String         @default("PENDING") // PENDING, NOTIFIED, CONVERTED
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("mb_waitlist_lead")
}

// ─────────────────────────────────────────────────────────────────────────────
// CREDIT NOTES
// ─────────────────────────────────────────────────────────────────────────────

model CreditNote {
  id            String           @id @default(cuid())
  tenantId      String
  shopId        String
  creditNoteNo  String
  date          DateTime         @default(now())
  financialYear String?

  // Party linkage — one of these is set
  customerId   String? // CUSTOMER type: issued TO customer
  supplierId   String? // SUPPLIER type: received FROM supplier

  // Source document
  linkedInvoiceId  String? // Against a specific sales invoice
  linkedPurchaseId String? // Against a specific supplier invoice

  type   CreditNoteType   // CUSTOMER | SUPPLIER
  reason CreditNoteReason
  status CreditNoteStatus @default(DRAFT)

  subTotal      Int
  gstAmount     Int
  totalAmount   Int
  appliedAmount Int @default(0) // How much has been offset against invoices
  refundedAmount Int @default(0)

  notes      String?
  voidReason String?
  voidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  items        CreditNoteItem[]
  applications CreditNoteApplication[]

  customer  Party?    @relation("CustomerCreditNotes", fields: [customerId], references: [id])
  supplier  Party?    @relation("SupplierCreditNotes", fields: [supplierId], references: [id])
  invoice   Invoice?  @relation("InvoiceCreditNotes", fields: [linkedInvoiceId], references: [id])
  purchase  Purchase? @relation("PurchaseCreditNotes", fields: [linkedPurchaseId], references: [id])
  shop      Shop      @relation(fields: [shopId], references: [id])
  tenant    Tenant    @relation("TenantCreditNotes", fields: [tenantId], references: [id])

  @@unique([shopId, creditNoteNo])
  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([supplierId])
  @@map("mb_credit_note")
}

model CreditNoteItem {
  id            String      @id @default(cuid())
  creditNoteId  String
  shopProductId String?
  description   String
  quantity      Int
  rate          Int
  hsnCode       String?
  gstRate       Float       @default(0)
  gstAmount     Int         @default(0)
  lineTotal     Int
  restockItem   Boolean     @default(false) // true = return goods to inventory

  creditNote CreditNote   @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product    ShopProduct? @relation(fields: [shopProductId], references: [id])

  @@index([creditNoteId])
  @@map("mb_credit_note_item")
}

// Tracks how a CN is applied against invoices/purchases
model CreditNoteApplication {
  id           String    @id @default(cuid())
  creditNoteId String
  invoiceId    String? // Applied against a customer invoice
  purchaseId   String? // Applied against a supplier invoice
  amount       Int
  appliedAt    DateTime  @default(now())
  appliedBy    String

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id])
  invoice    Invoice?   @relation("InvoiceCNApplications", fields: [invoiceId], references: [id])
  purchase   Purchase?  @relation("PurchaseCNApplications", fields: [purchaseId], references: [id])

  @@index([creditNoteId])
  @@map("mb_credit_note_application")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEW ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum QuotationConversionType {
  INVOICE
  JOB_CARD
}

enum CreditNoteType {
  CUSTOMER
  SUPPLIER
}

enum CreditNoteReason {
  SALES_RETURN
  PURCHASE_RETURN
  PRICE_ADJUSTMENT
  DISCOUNT_POST_SALE
  OVERBILLING
  WARRANTY_CLAIM
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  PARTIALLY_APPLIED
  FULLY_APPLIED
  REFUNDED
  VOIDED
}

model SystemAiConfig {
  id               String   @id @default(cuid())
  provider         String   @default("OLLAMA") // OLLAMA, OPENAI, ANTHROPIC 
  baseUrl          String?  // e.g., http://localhost_REPLACED:11434
  apiKey           String?  // Keep null for OLLAMA, use API keys for cloud providers
  defaultModel     String   @default("llama3:8b")
  embeddingModel   String?  @default("nomic-embed-text")
  isActive         Boolean  @default(true)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  @@map("mb_system_ai_config")
}
