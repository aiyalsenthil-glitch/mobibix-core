model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  module               ModuleType         @default(MOBILE_SHOP)
  status               SubscriptionStatus
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt @db.Timestamp(6)
  expiryReminderSentAt DateTime?          @db.Timestamp(6)

  // Phase 1: Billing Migration Fields
  billingCycle      BillingCycle? // MONTHLY, QUARTERLY, YEARLY (null = use plan.billingCycle for compat)
  priceSnapshot     Int? // Price locked at subscription creation (paise)
  autoRenew         Boolean       @default(false) // Auto-renew disabled by default
  nextPlanId        String? // For scheduled downgrades
  nextBillingCycle  BillingCycle? // For scheduled duration changes
  nextPriceSnapshot Int? // Price for next cycle (when upgrading)
  lastRenewedAt     DateTime? // Track when last renewed (for audit)

  // AI Governance
  aiTokensUsed     Int       @default(0)
  lastQuotaResetAt DateTime? @db.Timestamp(6)

  // Hybrid Billing Fields
  billingType            BillingType    @default(MANUAL)
  paymentStatus          PaymentStatus  @default(PENDING)
  autopayStatus          AutopayStatus?
  providerSubscriptionId String? // For AutoPay (sub_...)
  providerPaymentLinkId  String? // For Manual (plink_...)

  plan   Plan                @relation(fields: [planId], references: [id])
  tenant Tenant              @relation(fields: [tenantId], references: [id])
  addons SubscriptionAddon[] // Add-ons attached to this subscription

  @@unique([tenantId, module, endDate])
  @@index([tenantId, module, status], name: "idx_subscription_lookup")
  @@index([tenantId])
  @@index([planId])
  @@index([module])
  @@index([autoRenew])
  @@index([providerSubscriptionId])
  @@index([providerPaymentLinkId])
  @@index([status, module])
  @@index([tenantId, status, endDate]) // Optimized for expiry cron
}

model SubscriptionAddon {
  id             String             @id @default(cuid())
  subscriptionId String // Reference to base subscription
  addonPlanId    String // Reference to add-on plan (e.g., WHATSAPP_CRM)
  status         SubscriptionStatus @default(ACTIVE)
  startDate      DateTime
  endDate        DateTime

  // Billing fields
  billingCycle  BillingCycle? // MONTHLY, QUARTERLY, YEARLY
  priceSnapshot Int? // Price locked at addon creation (paise)
  autoRenew     Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  addonPlan    Plan               @relation("AddonPlans", fields: [addonPlanId], references: [id])

  @@unique([subscriptionId, addonPlanId])
  @@index([subscriptionId])
  @@index([addonPlanId])
}

model Payment {
  id                  String               @id @default(cuid())
  tenantId            String
  planId              String
  module              ModuleType           @default(MOBILE_SHOP)
  billingCycle        BillingCycle
  priceSnapshot       Int
  amount              Int
  currency            String               @default("INR")
  status              PaymentStatus
  provider            String
  providerOrderId     String
  providerPaymentId   String?
  providerSignature   String?
  meta                Json?
