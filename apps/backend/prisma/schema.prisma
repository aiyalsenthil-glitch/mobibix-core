enum ProductType {
  GOODS
  SPARE
  SERVICE
}

enum WhatsAppPhoneNumberPurpose {
  REMINDER
  BILLING
  MARKETING
  DEFAULT
}

enum WhatsAppFeature {
  WELCOME
  EXPIRY
  PAYMENT_DUE
  REMINDER
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String                 @id @default(cuid())
  name             String
  legalName        String?
  tenantType       String
  code             String                 @unique
  contactPhone     String?
  contactEmail     String?
  website          String?
  logoUrl          String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  pincode          String?
  country          String                 @default("India")
  gstNumber        String?
  taxId            String?
  businessType     String?
  currency         String                 @default("INR")
  timezone         String                 @default("Asia/Kolkata")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  kioskToken       String?                @unique
  maxMembers       Int                    @default(50)
  whatsappEnabled  Boolean                @default(true)
  auditLogs        AuditLog[]
  members          Member[]
  payments         Payment[]
  subscription     TenantSubscription[]
  users            User[]
  userTenants      UserTenant[]
  shops            Shop[]
  shopStaffs       ShopStaff[]
  jobCards         JobCard[]
  shopProducts     ShopProduct[]
  stockEntries     StockLedger[]
  stockCorrections StockCorrection[]
  invoices         Invoice[]
  financialEntries FinancialEntry[]
  ledgerCustomers  LedgerCustomer[]
  ledgerAccounts   LedgerAccount[]
  customers        Customer[]
  imeis            IMEI[]
  suppliers        Supplier[]
  globalSuppliers  TenantGlobalSupplier[]
  purchases        Purchase[]
  receipts         Receipt[]
  paymentVouchers  PaymentVoucher[]
  quotations       Quotation[]
  purchaseOrders   PurchaseOrder[]

  // CRM Relations
  customerFollowUps   CustomerFollowUp[]
  customerReminders   CustomerReminder[]
  loyaltyTransactions LoyaltyTransaction[]
  customerAlerts      CustomerAlert[]
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model User {
  id               String       @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid      String       @unique
  email            String?
  fullName         String?
  avatar           String?
  role             UserRole
  tenantId         String?
  permissions      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  phone            String?
  welcomeEmailSent Boolean      @default(false)
  auditLogs        AuditLog[]
  platformAuditLogs PlatformAuditLog[]
  tenant           Tenant?      @relation(fields: [tenantId], references: [id])
  userTenants      UserTenant[]
  shopStaffs       ShopStaff[]

  // CRM: Follow-ups assigned to this user
  assignedFollowUps CustomerFollowUp[]
}

model Member {
  id                  String              @id @default(uuid())
  tenantId            String
  fullName            String
  phone               String
  gender              Gender
  membershipPlanId    String
  membershipStartAt   DateTime
  membershipEndAt     DateTime
  feeAmount           Int
  paymentStatus       MemberPaymentStatus
  heightCm            Float
  weightKg            Float
  fitnessGoal         FitnessGoal
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  paidAmount          Int                 @default(0)
  monthlyFee          Int
  paymentDueDate      DateTime
  paymentReminderSent Boolean             @default(false)
  isActive            Boolean             @default(true)
  photoUrl            String?
  welcomeMessageSent  Boolean             @default(false)
  attendances         GymAttendance[]
  gymMemberships      GymMembership[]
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  payments            MemberPayment[]

  @@unique([id, tenantId])
  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Customer {
  id       String @id @default(cuid())
  tenantId String

  name  String
  phone String
  email String?

  state     String
  gstNumber String?

  businessType BusinessType @default(B2C)
  partyType    PartyType    @default(CUSTOMER)

  loyaltyPoints Int     @default(0)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]
  jobCards JobCard[]

  // CRM Relations
  followUps           CustomerFollowUp[]
  reminders           CustomerReminder[]
  loyaltyTransactions LoyaltyTransaction[]
  alerts              CustomerAlert[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

// ============= CRM MODELS =============

// Track manual CRM actions: calls, WhatsApp, visits, etc.
model CustomerFollowUp {
  id         String  @id @default(cuid())
  tenantId   String
  customerId String
  shopId     String?

  type       FollowUpType
  purpose    FollowUpPurpose
  note       String?
  followUpAt DateTime
  status     FollowUpStatus  @default(PENDING)

  assignedToUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop           Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  assignedToUser User?    @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([customerId])
  @@index([shopId])
  @@index([assignedToUserId])
  @@index([followUpAt])
  @@index([status])
}

// Automated reminders: schedule WhatsApp or in-app notifications
model CustomerReminder {
  id         String @id @default(cuid())
  tenantId   String
  customerId String

  triggerType  ReminderTriggerType
  triggerValue String // Date string (YYYY-MM-DD) or number of days as string
  channel      ReminderChannel
  templateKey  String // Template identifier for rendering

  status        ReminderStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  sentAt        DateTime?
  failureReason String? // Optional: reason if status = FAILED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
}

// Track loyalty points earned/redeemed
model LoyaltyTransaction {
  id         String @id @default(cuid())
  tenantId   String
  customerId String

  points      Int // Positive (earned) or negative (redeemed)
  source      LoyaltySource
  referenceId String? // Link to Invoice, Manual action, etc.
  note        String?

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([createdAt])
}

// Internal alerts for staff on customer actions/statuses
model CustomerAlert {
  id         String @id @default(cuid())
  tenantId   String
  customerId String

  severity   AlertSeverity
  message    String
  source     AlertSource
  resolved   Boolean       @default(false)
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
}

model LedgerCustomer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  ledgers LedgerAccount[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model LedgerAccount {
  id         String @id @default(cuid())
  tenantId   String
  customerId String

  principalAmount   Int
  expectedTotal     Int
  installmentType   LedgerInstallmentType
  installmentAmount Int
  totalPeriods      Int

  startDate DateTime
  status    LedgerStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  customer LedgerCustomer @relation(fields: [customerId], references: [id])

  collections LedgerCollection[]

  @@index([tenantId])
  @@index([customerId])
}

model LedgerCollection {
  id       String @id @default(cuid())
  tenantId String
  ledgerId String

  periodNo Int
  dueDate  DateTime
  amount   Int
  paid     Boolean   @default(false)
  paidAt   DateTime?

  createdAt DateTime @default(now())

  ledger LedgerAccount @relation(fields: [ledgerId], references: [id])

  @@index([tenantId])
  @@index([ledgerId])
}

model StaffInvite {
  id        String   @id @default(cuid())
  email     String
  tenantId  String
  createdAt DateTime @default(now())
  accepted  Boolean  @default(false)
  role      UserRole @default(STAFF)
  name      String?
  phone     String?

  @@unique([tenantId, email])
}

model MemberPayment {
  id           String              @id @default(cuid())
  tenantId     String
  memberId     String
  amount       Int
  status       MemberPaymentStatus
  method       String?
  reference    String?
  gstRate      Float?
  gstAmount    Float?
  total        Int?
  createdAt    DateTime            @default(now())
  durationDays Int?
  member       Member              @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Plan {
  id            String               @id @default(uuid())
  code          String?              @unique
  name          String               @unique
  level         Int
  price         Int
  currency      String               @default("INR")
  durationDays  Int
  memberLimit   Int                  @default(0)
  maxMembers    Int?
  features      Json?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  billingCycle  BillingCycle         @default(MONTHLY)
  subscriptions TenantSubscription[]
  planFeatures  PlanFeature[]
}

model PlanFeature {
  id      String          @id @default(uuid())
  planId  String
  feature WhatsAppFeature
  enabled Boolean         @default(true)

  plan Plan @relation(fields: [planId], references: [id])

  @@unique([planId, feature])
  @@index([planId])
}

model TenantSubscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt @db.Timestamp(6)
  expiryReminderSentAt DateTime?          @db.Timestamp(6)
  plan                 Plan               @relation(fields: [planId], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([planId])
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  planId            String
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus
  provider          String
  providerOrderId   String
  providerPaymentId String?
  providerSignature String?
  meta              Json?
  createdAt         DateTime      @default(now())
  tenant            Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([provider, providerPaymentId, providerOrderId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model PlatformAuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model GymMembership {
  id        String           @id @default(cuid())
  tenantId  String
  memberId  String
  startDate DateTime
  endDate   DateTime
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  member    Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model WhatsAppSetting {
  id                     String   @id @default(uuid())
  tenantId               String   @unique
  enabled                Boolean  @default(false)
  createdAt              DateTime @default(now())
  provider               String?
  defaultLanguage        String   @default("en")
  dailyLimit             Int?
  testPhone              String?
  marketingOptInRequired Boolean  @default(true)
}

model WhatsAppPhoneNumber {
  id            String                      @id @default(uuid())
  tenantId      String
  phoneNumber   String // E.164 format e.g., +919876543210
  phoneNumberId String // Meta Phone Number ID (used in API calls)
  wabaId        String // WhatsApp Business Account ID
  purpose       WhatsAppPhoneNumberPurpose  @default(DEFAULT)
  qualityRating String? // Meta quality rating (read-only)
  isDefault     Boolean                     @default(false)
  isActive      Boolean                     @default(true)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@unique([tenantId, phoneNumberId])
  @@index([tenantId, isActive])
  @@index([tenantId, purpose])
}

model WhatsAppLog {
  id         String   @id @default(uuid())
  tenantId   String
  memberId   String?
  phone      String
  type       String   // WELCOME, PAYMENT_DUE, EXPIRY, etc.
  status     String   // PENDING, SENT, DELIVERED, READ, FAILED
  error      String?  // Error message if status = FAILED
  messageId  String?  // Meta message ID returned from API (for webhook tracking)
  metadata   Json?    // Additional metadata (template vars, etc.)
  sentAt     DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  deliveredAt DateTime?
  readAt     DateTime?

  @@index([tenantId, sentAt])
  @@index([tenantId, status])
  @@index([messageId]) // For webhook lookups
}

model WhatsAppTemplate {
  id               String   @id @default(uuid())
  moduleType       String // GYM, MOBILESHOP - module-level templates shared across tenants
  templateKey      String // WELCOME, PAYMENT_DUE, EXPIRY, REMINDER (immutable - identifies purpose)
  metaTemplateName String // "new_member_welcome_v3", "payment_reminder_v2", etc. (Meta WhatsApp template name, can vary per version)
  category         String // UTILITY or MARKETING
  feature          String // WELCOME, PAYMENT_DUE, EXPIRY, REMINDER
  language         String   @default("en") // en, ta, hi
  status           String   @default("ACTIVE") // ACTIVE or DISABLED
  isDefault        Boolean  @default(false) // Which version is the default for this templateKey
  variables        Json? // Array of variable keys used by this template version
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([moduleType, metaTemplateName]) // metaTemplateName must be unique across Meta (can't have duplicate names)
  @@index([moduleType])
  @@index([moduleType, templateKey]) // Allow querying all versions of a template key
}

model WhatsAppAutomation {
  id          String              @id @default(uuid())
  moduleType  String // GYM, MOBILESHOP - module-level automations
  triggerType ReminderTriggerType // DATE, AFTER_INVOICE, AFTER_JOB
  templateKey String // Reference to WhatsAppTemplate.templateKey (same moduleType)
  offsetDays  Int // Days before/after trigger date
  enabled     Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([moduleType])
  @@index([moduleType, triggerType])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventType   String
  referenceId String?
  payload     Json
  receivedAt  DateTime @default(now())
}

model WebhookLog {
  id        String   @id @default(uuid())
  provider  String
  event     String
  entityId  String?
  tenantId  String?
  planId    String?
  status    String
  payload   Json
  error     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([event])
}

model GymAttendance {
  id           String           @id @default(cuid())
  tenantId     String
  memberId     String
  checkInTime  DateTime
  checkOutTime DateTime?
  source       AttendanceSource @default(MANUAL)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  member       Member           @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model Shop {
  id            String  @id @default(cuid())
  tenantId      String
  name          String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  pincode       String
  gstNumber     String?
  gstEnabled    Boolean @default(false)
  invoicePrefix String
  logoUrl       String?
  website       String?
  invoiceFooter String?

  // Print Configuration
  invoicePrinterType String? @default("NORMAL")
  invoiceTemplate    String? @default("CLASSIC")
  jobCardPrinterType String? @default("NORMAL")
  jobCardTemplate    String? @default("SIMPLE")

  // Custom Header
  headerConfig Json?
  tagline      String?

  terms String[] @default([])

  // Bank Details
  bankName      String?
  accountNumber String?
  ifscCode      String?
  branchName    String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff            ShopStaff[]
  jobCards         JobCard[]
  products         ShopProduct[]
  stockEntries     StockLedger[]
  stockCorrections StockCorrection[]
  invoices         Invoice[]
  transferredIMEIs IMEI[]            @relation("TransferredIMEIs") // IMEIs transferred TO this shop

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  financialEntries FinancialEntry[]
  purchases        Purchase[]
  receipts         Receipt[]
  paymentVouchers  PaymentVoucher[]
  quotations       Quotation[]
  purchaseOrders   PurchaseOrder[]
  documentSettings ShopDocumentSetting[] // ✅ NEW: Per-document numbering config

  // CRM: Follow-ups linked to this shop
  followUps CustomerFollowUp[]

  receiptPrintCounter Int @default(0) // Atomic counter for receipt numbers

  @@unique([tenantId, invoicePrefix])
  @@index([tenantId])
}

// ✅ NEW: Per-shop, per-document-type numbering configuration
// Replaces hardcoded invoice numbering with fully customizable system
model ShopDocumentSetting {
  id           String       @id @default(cuid())
  shopId       String
  documentType DocumentType

  // Format configuration
  prefix       String // e.g., "HP" (shop identifier)
  separator    String      @default("-") // Separator between parts (-, /, _, etc.)
  documentCode String // e.g., "S" (Sales), "P" (Purchase), "J" (Job Card)
  yearFormat   YearFormat  @default(FY) // How to display year
  numberLength Int         @default(4) // Padding (0001, 00001, etc.)
  resetPolicy  ResetPolicy @default(YEARLY) // When to reset counter

  // Current state (for atomic increments)
  currentNumber Int     @default(0) // Last used sequence number
  currentYear   String? // Last used year (for auto-reset detection)

  // Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, documentType]) // One config per shop per document type
  @@index([shopId])
  @@index([documentType])
}

model ShopStaff {
  id        String   @id @default(cuid())
  tenantId  String
  shopId    String
  userId    String
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, shopId])
  @@index([tenantId])
  @@index([shopId])
}

model JobCard {
  id       String @id @default(cuid())
  tenantId String
  shopId   String

  customerId String? // ✅ NEW (nullable)
  customer   Customer? @relation(fields: [customerId], references: [id])

  jobNumber   String
  publicToken String @unique

  // 🔒 KEEP LEGACY FIELDS FOR NOW
  customerName     String
  customerPhone    String
  customerAltPhone String?

  // Device
  deviceType     String // Mobile, Laptop, etc.
  deviceBrand    String
  deviceModel    String
  deviceSerial   String? // IMEI / SNO
  devicePassword String? // Device lock/password

  // Issue
  customerComplaint String
  physicalCondition String?

  // Financial
  estimatedCost     Int?
  diagnosticCharge  Int?      @default(0)
  advancePaid       Int       @default(0)
  finalCost         Int?
  billType          String    @default("WITHOUT_GST") // WITHOUT_GST, WITH_GST
  estimatedDelivery DateTime?

  // Advance Payment
  advancePaymentMethod String? // Cash, UPI, Mixed
  advanceCashAmount    Int?
  advanceUpiAmount     Int?

  // Consent & Warranty
  warrantyDuration     Int?    @default(0) // days
  consentAcknowledge   Boolean @default(false)
  consentDataLoss      Boolean @default(false)
  consentDiagnosticFee Boolean @default(false)

  // Meta
  createdByUserId String
  createdByName   String

  status JobStatus @default(RECEIVED)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  shop      Shop             @relation(fields: [shopId], references: [id])
  partsUsed RepairPartUsed[]

  @@unique([shopId, jobNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([customerId]) // ✅ NEW
}

model HSNCode {
  id          String          @id @default(cuid())
  code        String          @unique
  description String?
  taxRate     Float
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  hsnProducts GlobalProduct[]
}

model ProductCategory {
  id               String          @id @default(cuid())
  name             String          @unique
  createdAt        DateTime        @default(now())
  categoryProducts GlobalProduct[]
}

model GlobalProduct {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  hsnId      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  category     ProductCategory @relation(fields: [categoryId], references: [id])
  hsn          HSNCode         @relation(fields: [hsnId], references: [id])
  shopProducts ShopProduct[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([hsnId])
}

model ShopProduct {
  id              String      @id @default(cuid())
  tenantId        String
  shopId          String
  globalProductId String? // Can be null for custom shop-specific products
  name            String
  salePrice       Int?
  costPrice       Int?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  type            ProductType // GOODS, SPARE, SERVICE
  category        String? // Free text category (e.g. Charger, Cover)

  // ✅ NEW: isSerialized flag to distinguish tracked units from bulk items
  // TRUE (serialized) = track IMEI per unit (mobiles, laptops)
  // FALSE (bulk) = track quantity via StockLedger (accessories, spares)
  isSerialized Boolean @default(false)

  // Tax & HSN (Local override or standalone)
  hsnCode String?
  gstRate Float?  @default(0)

  // Stock & Inventory
  // 🔴 REMOVED: stockOnHand (was causing confusion - StockLedger is the ONLY source of truth)
  // For current stock: Calculate from StockLedger (bulk) or count IMEI with status=IN_STOCK (serialized)
  reorderLevel Int?
  reorderQty   Int?
  barcode      String?
  location     String? // Physical shelf location

  imeis            IMEI[] // For MOBILE only
  stockEntries     StockLedger[]
  stockCorrections StockCorrection[]
  invoiceItems     InvoiceItem[]
  partsUsed        RepairPartUsed[]
  purchaseItems    PurchaseItem[]

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  shop   Shop           @relation(fields: [shopId], references: [id])
  global GlobalProduct? @relation(fields: [globalProductId], references: [id])

  @@unique([shopId, name])
  @@index([tenantId])
  @@index([shopId])
  @@index([globalProductId])
}

model IMEI {
  id                  String     @id @default(cuid())
  tenantId            String
  shopProductId       String
  imei                String // ✅ FIXED: Unique per tenant (not globally)
  status              IMEIStatus @default(IN_STOCK) // Unit lifecycle status
  invoiceId           String? // Linked invoice when SOLD
  transferredToShopId String? // Destination shop when TRANSFERRED
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // Audit trail for unit lifecycle
  soldAt      DateTime? // When was this unit sold
  returnedAt  DateTime? // When was this unit returned
  damageNotes String? // Why is unit damaged (DAMAGED status)
  lostReason  String? // Why is unit lost (LOST status - irreversible)

  product           ShopProduct @relation(fields: [shopProductId], references: [id])
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  invoice           Invoice?    @relation(fields: [invoiceId], references: [id])
  transferredToShop Shop?       @relation("TransferredIMEIs", fields: [transferredToShopId], references: [id])

  @@unique([tenantId, imei]) // ✅ CRITICAL: Tenant-scoped uniqueness for multi-tenant SaaS
  @@index([tenantId])
  @@index([shopProductId])
  @@index([invoiceId])
  @@index([status])
  @@index([transferredToShopId])
}

model StockLedger {
  id            String         @id @default(cuid())
  tenantId      String
  shopId        String
  shopProductId String
  type          StockEntryType // IN (purchase, transfer) or OUT (sale, repair, adjustment)
  quantity      Int // Must be positive; validate before OUT to prevent negatives
  referenceType StockRefType? // PURCHASE, SALE, REPAIR, ADJUSTMENT, TRANSFER
  referenceId   String? // PurchaseItem.id, InvoiceItem.id, RepairPartUsed.id, etc.
  costPerUnit   Int? // ✅ NEW: Cost per unit for COGS calculation
  note          String?
  createdAt     DateTime       @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  shop    Shop        @relation(fields: [shopId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([tenantId, shopId, createdAt])
  @@index([shopProductId, createdAt])
  @@index([tenantId, shopId, type])
  @@index([referenceType, referenceId]) // ✅ NEW: Trace movements by reference
}

model StockCorrection {
  id            String   @id @default(cuid())
  tenantId      String
  shopId        String
  shopProductId String
  quantity      Int
  reason        String
  note          String?
  createdBy     String?
  createdAt     DateTime @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  shop    Shop        @relation(fields: [shopId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([tenantId, shopId])
  @@index([shopProductId])
  @@index([createdAt])
}

model Invoice {
  id       String @id @default(cuid())
  tenantId String
  shopId   String

  customerId String? // ✅ NEW (nullable, SAFE)
  customer   Customer? @relation(fields: [customerId], references: [id])

  invoiceNumber String
  invoiceDate   DateTime @default(now())
  financialYear String?
  customerName  String
  customerPhone String?
  customerGstin String?
  customerState String?

  subTotal    Int
  gstAmount   Int
  cgst        Int?
  sgst        Int?
  igst        Int?
  totalAmount Int

  paymentMode PaymentMode
  cashAmount  Int?
  upiAmount   Int?
  cardAmount  Int?

  status    InvoiceStatus @default(PAID)
  createdAt DateTime      @default(now())
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  items    InvoiceItem[]
  imeis    IMEI[] // IMEIs sold via this invoice
  receipts Receipt[] // Linked payments

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId]) // ✅ NEW (for history lookup)
}

model InvoiceItem {
  id            String @id @default(cuid())
  invoiceId     String
  shopProductId String
  quantity      Int
  rate          Int
  hsnCode       String
  gstRate       Float
  gstAmount     Int
  lineTotal     Int

  invoice Invoice     @relation(fields: [invoiceId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@index([invoiceId])
}

model RepairPartUsed {
  id            String   @id @default(cuid())
  jobCardId     String
  shopProductId String
  quantity      Int
  costPerUnit   Int? // ✅ Snapshot from StockLedger.costPerUnit (denormalized for reporting)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ⚠️ CRITICAL: Stock Impact Rules
  // 1. When created: MUST create StockLedger OUT entry with referenceType=REPAIR
  // 2. When job cancelled: MUST create StockLedger IN entry to reverse the OUT
  // 3. costPerUnit: Copy from corresponding StockLedger OUT entry (source of truth)
  // 4. Never calculate from product.costPrice (use StockLedger.costPerUnit)
  // 5. LOST status: Treated as irreversible OUT (no reversal allowed)
  jobCard JobCard     @relation(fields: [jobCardId], references: [id])
  product ShopProduct @relation(fields: [shopProductId], references: [id])

  @@unique([jobCardId, shopProductId])
  @@index([jobCardId])
  @@index([shopProductId])
}

model FinancialEntry {
  id            String          @id @default(cuid())
  tenantId      String
  shopId        String
  type          FinanceType
  amount        Int
  mode          PaymentMode
  referenceType FinanceRefType?
  referenceId   String?
  note          String?
  createdAt     DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
}

// ============= SUPPLIER MANAGEMENT =============

model Supplier {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  namelowercase       String // For case-insensitive search
  primaryPhone        String
  altPhone            String?
  email               String?
  gstin               String?
  address             String?
  state               String?
  defaultPaymentTerms String? // e.g., '30 days', 'COD'
  defaultCreditLimit  Int?
  defaultCurrency     String   @default("INR")
  tags                String[] @default([]) // parts, accessories, etc.
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  shopSuppliers ShopSupplier[]
  purchases     Purchase[]

  @@unique([tenantId, namelowercase])
  @@index([tenantId])
}

model ShopSupplier {
  id                 String   @id @default(cuid())
  tenantId           String
  shopId             String
  globalSupplierId   String?
  name               String
  namelowercase      String // For case-insensitive search
  phone              String?
  email              String?
  gstin              String?
  outstandingAmount  Int      @default(0)
  openPurchasesCount Int      @default(0)
  localNotes         String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?

  supplier Supplier? @relation(fields: [globalSupplierId], references: [id])

  @@unique([shopId, namelowercase])
  @@index([tenantId])
  @@index([shopId])
}

// ============= GLOBAL SUPPLIERS (Available to all tenants) =============

model GlobalSupplier {
  id                  String   @id @default(cuid())
  name                String
  namelowercase       String   @unique // For case-insensitive search
  primaryPhone        String?
  altPhone            String?
  email               String?
  gstin               String?
  address             String?
  state               String?
  country             String   @default("India")
  defaultPaymentTerms String?
  defaultCreditLimit  Int?
  defaultCurrency     String   @default("INR")
  tags                String[] @default([])
  isVerified          Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?

  tenants TenantGlobalSupplier[]

  @@index([isActive])
  @@index([namelowercase])
}

model TenantGlobalSupplier {
  id               String   @id @default(cuid())
  tenantId         String
  globalSupplierId String
  linkedAt         DateTime @default(now())
  localName        String? // Tenant can customize the name
  localPhone       String?
  localNotes       String?

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  globalSupplier GlobalSupplier @relation(fields: [globalSupplierId], references: [id], onDelete: Cascade)

  @@unique([tenantId, globalSupplierId])
  @@index([tenantId])
  @@index([globalSupplierId])
}

// ============= PURCHASE MANAGEMENT =============

model Purchase {
  id               String    @id @default(cuid())
  tenantId         String
  shopId           String
  invoiceNumber    String
  globalSupplierId String?
  supplierName     String
  invoiceDate      DateTime  @default(now())
  dueDate          DateTime?

  subTotal   Int
  totalGst   Int
  grandTotal Int
  paidAmount Int @default(0)

  paymentMethod    PaymentMode
  paymentReference String?
  cashAmount       Int?
  upiAmount        Int?

  purchaseType String         @default("Goods") // Goods, Service
  taxInclusive Boolean        @default(false)
  status       PurchaseStatus @default(DRAFT)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  shop     Shop              @relation(fields: [shopId], references: [id])
  supplier Supplier?         @relation(fields: [globalSupplierId], references: [id])
  items    PurchaseItem[]
  payments SupplierPayment[]

  @@unique([shopId, invoiceNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([globalSupplierId])
}

model PurchaseItem {
  id            String  @id @default(cuid())
  purchaseId    String
  shopProductId String?
  description   String
  hsnSac        String?
  quantity      Int
  purchasePrice Int
  gstRate       Float   @default(0)
  taxAmount     Int     @default(0)
  totalAmount   Int

  createdAt DateTime @default(now())

  purchase Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  ShopProduct? @relation(fields: [shopProductId], references: [id])

  @@index([purchaseId])
  @@index([shopProductId])
}

// ============= SUPPLIER PAYMENTS =============

model SupplierPayment {
  id               String      @id @default(cuid())
  tenantId         String
  shopId           String
  purchaseId       String?
  globalSupplierId String?
  amount           Int
  paymentMethod    PaymentMode
  paymentReference String?
  paymentDate      DateTime    @default(now())
  notes            String?

  createdAt DateTime @default(now())
  createdBy String?

  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([purchaseId])
}

// ============= RECEIPTS & PAYMENTS =============

model Receipt {
  id             String      @id @default(cuid())
  tenantId       String
  shopId         String
  receiptId      String      @unique
  printNumber    String // Sequential print number
  receiptType    ReceiptType
  amount         Int
  paymentMethod  PaymentMode
  transactionRef String? // UPI ref, cheque number, etc.

  customerId    String?
  customerName  String
  customerPhone String?

  linkedInvoiceId String?
  linkedJobId     String?

  narration String?
  status    ReceiptStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  createdBy String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  shop    Shop     @relation(fields: [shopId], references: [id])
  invoice Invoice? @relation(fields: [linkedInvoiceId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([linkedInvoiceId])
}

model PaymentVoucher {
  id             String      @id @default(cuid())
  tenantId       String
  shopId         String
  voucherId      String      @unique
  voucherType    VoucherType
  date           DateTime    @default(now())
  amount         Int
  paymentMethod  PaymentMode
  transactionRef String?
  narration      String?

  globalSupplierId String?
  expenseCategory  String? // rent, eb, tea, donation, misc
  linkedPurchaseId String?

  status VoucherStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@index([tenantId])
  @@index([shopId])
}

// ============= QUOTATIONS =============

model Quotation {
  id              String   @id @default(cuid())
  tenantId        String
  shopId          String
  quotationNumber String
  customerId      String?
  customerName    String
  quotationDate   DateTime @default(now())

  items        QuotationItem[]
  totalAmount  Int             @default(0)
  notes        String?
  status       QuotationStatus @default(DRAFT)
  validityDays Int             @default(30)
  expiryDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, quotationNumber])
  @@index([tenantId])
  @@index([shopId])
}

model QuotationItem {
  id          String @id @default(cuid())
  quotationId String
  description String
  quantity    Int
  price       Int
  totalAmount Int

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

// ============= PURCHASE ORDERS =============

model PurchaseOrder {
  id               String    @id @default(cuid())
  tenantId         String
  shopId           String
  poNumber         String
  globalSupplierId String?
  supplierName     String
  orderDate        DateTime  @default(now())
  expectedDelivery DateTime?

  items                PurchaseOrderItem[]
  totalEstimatedAmount Int                 @default(0)
  notes                String?
  status               POStatus            @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  shop   Shop   @relation(fields: [shopId], references: [id])

  @@unique([shopId, poNumber])
  @@index([tenantId])
  @@index([shopId])
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  poId             String
  globalProductId  String?
  description      String
  quantity         Int
  estimatedPrice   Int?
  receivedQuantity Int     @default(0)

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
}

