generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  lastLoginAt              DateTime?
  id                       String                  @id @default(cuid())
  name                     String
  legalName                String?
  tenantType               String
  code                     String                  @unique
  contactPhone             String?
  contactEmail             String?
  website                  String?
  logoUrl                  String?
  addressLine1             String?
  addressLine2             String?
  city                     String?
  state                    String?
  pincode                  String?
  country                  String                  @default("India")
  stateCode                String?
  gstNumber                String?
  taxId                    String?
  businessType             String?
  businessCategoryId       String?
  currency                 String                  @default("INR")
  timezone                 String                  @default("Asia/Kolkata")
  taxSystem                String                  @default("GST")
  createdAt                DateTime                @default(now())
  createdBy                String?
  updatedAt                DateTime                @updatedAt
  updatedBy                String?
  deletedAt                DateTime?
  deletedBy                String?
  kioskToken               String?                 @unique
  enabledModules           ModuleType[]
  maxMembers               Int                     @default(50)
  gymUpiId                 String?
  whatsappEnabled          Boolean                 @default(true)
  whatsappCrmEnabled       Boolean                 @default(false)
  whatsappPhoneNumberId    String?
  whatsappBusinessId       String?
  whatsappWabaId           String?
  whatsappReminderNumberId String?
  termsAcceptedAt          DateTime?
  privacyAcceptedAt        DateTime?
  marketingConsent         Boolean                 @default(false)
  acceptedPolicyVersion    String?
  consentIpAddress         String?
  consentUserAgent         String?
  domain                   String?
  deletionRequestPending   Boolean                 @default(false)
  deletionScheduledAt      DateTime?
  status                   TenantStatus            @default(ACTIVE)
  partnerId                String?
  promoCodeId              String?
  approvalRequests         ApprovalRequest[]
  billingEventLogs         BillingEventLog[]
  deletionRequests         DeletionRequest[]       @relation("TenantDeletionRequests")
  emailLogs                EmailLog[]
  featureFlags             FeatureFlag[]           @relation("TenantFeatureFlags")
  payments                 Payment[]
  roles                    Role[]
  invites                  StaffInvite[]
  subscriptionInvoices     SubscriptionInvoice[]   @relation("TenantToSubscriptionInvoice")
  businessCategory         BusinessCategory?       @relation("TenantBusinessCategory", fields: [businessCategoryId], references: [id])
  partner                  Partner?                @relation(fields: [partnerId], references: [id])
  appliedPromoCode         PromoCode?              @relation(fields: [promoCodeId], references: [id])
  whatsappReminderNumber   WhatsAppNumber?         @relation("TenantReminderNumber", fields: [whatsappReminderNumberId], references: [id])
  subscription             TenantSubscription[]
  usageSnapshots           UsageSnapshot[]
  users                    User[]
  userTenants              UserTenant[]
  whatsAppCampaigns        WhatsAppCampaign[]
  whatsAppUsage            WhatsAppDailyUsage[]
  whatsAppNumbers          WhatsAppNumber[]        @relation("TenantWhatsAppNumbers")
  whatsAppMessageLogs      WhatsAppMessageLog[]
  whatsAppConversationStates WhatsAppConversationState[]
  healthScore              TenantHealthScore?
  aiUsageLogs              AiUsageLog[]
  members                  Member[]                @relation("TenantMembers")
  gymPlans                 GymPlan[]               @relation("TenantGymPlans")
  gymExpenses              GymExpense[]            @relation("TenantGymExpenses")
  gymClasses               GymClass[]              @relation("TenantGymClasses")
  ledgerAccounts           LedgerAccount[]
  ledgerCustomers          LedgerCustomer[]
  ledgerPayments           LedgerPayment[]
  auditLogs                AuditLog[]
  b2bPurchaseOrders        B2BPurchaseOrder[]
  cashVariances            CashVariance[]
  contacts                 Contact[]
  creditNotes              CreditNote[]            @relation("TenantCreditNotes")
  customerAlerts           CustomerAlert[]         @relation("TenantCustomerAlerts")
  customerFollowUps        CustomerFollowUp[]      @relation("TenantCustomerFollowUps")
  customerNotes            CustomerNote[]          @relation("TenantCustomerNotes")
  customerReminders        CustomerReminder[]      @relation("TenantCustomerReminders")
  dailyClosings            DailyClosing[]
  dailyMetrics             DailyMetrics[]
  distributorLinks         DistributorTenantLink[]
  financialEntries         FinancialEntry[]
  imeis                    IMEI[]
  invoices                 Invoice[]               @relation("TenantInvoices")
  jobCards                 JobCard[]               @relation("TenantJobCards")
  loyaltyAdjustments       LoyaltyAdjustment[]
  loyaltyConfigs           LoyaltyConfig[]
  loyaltyTransactions      LoyaltyTransaction[]
  notificationLogs         NotificationLog[]
  parties                  Party[]                 @relation("TenantParties")
  paymentVouchers          PaymentVoucher[]        @relation("TenantPaymentVouchers")
  purchases                Purchase[]              @relation("TenantPurchases")
  purchaseOrders           PurchaseOrder[]         @relation("TenantPurchaseOrders")
  quotations               Quotation[]             @relation("TenantQuotations")
  receipts                 Receipt[]               @relation("TenantReceipts")
  shiftClosings            ShiftClosing[]
  shops                    Shop[]
  shopProducts             ShopProduct[]
  shopStaffs               ShopStaff[]
  stockCorrections         StockCorrection[]
  stockEntries             StockLedger[]           @relation("TenantStockEntries")
  stockVerifications       StockVerification[]
  supplierPayments         SupplierPayment[]       @relation("TenantSupplierPayments")
  promoUsages              PromoUsage[]
  commissionRules          CommissionRule[]
  staffEarnings            StaffEarning[]
  tradeIns                 TradeIn[]
  eWayBills                EWayBill[]
  priceAlerts              SupplierPriceAlert[]
  emiApplications          EmiApplication[]
  installmentPlans         InstallmentPlan[]
  staffTargets             StaffTarget[]
  shopTargets              ShopTarget[]
  staffMilestones          StaffMilestone[]
  milestoneEarnings        MilestoneEarning[]
  automationRules          AutomationRule[]
  automationLogs           AutomationLog[]
  inboundEmails            InboundEmail[]
}

model DeletionRequest {
  id                String         @id @default(uuid())
  tenantId          String
  requestedBy       String
  requestedAt       DateTime       @default(now())
  reason            String?
  status            DeletionStatus @default(PENDING)
  adminNotes        String?
  resolvedAt        DateTime?
  originalEmail     String?
  originalLegalName String?
  originalPhone     String?
  originalGstNumber String?
  isHardDeleted     Boolean        @default(false)
  tenant            Tenant         @relation("TenantDeletionRequests", fields: [tenantId], references: [id])
}

model NotificationLog {
  id          String              @id @default(cuid())
  tenantId    String
  userId      String?
  eventId     String
  channel     NotificationChannel
  recipient   String
  status      NotificationStatus  @default(PENDING)
  payload     Json?
  errorReason String?
  retryCount  Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  sentAt      DateTime?
  readAt      DateTime?
  title       String?
  body        String?
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([eventId])
  @@index([createdAt])
  @@index([tenantId, channel, readAt])
  @@map("mb_notification_log")
}

model BusinessCategory {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  isActive     Boolean  @default(true)
  isComingSoon Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenants      Tenant[] @relation("TenantBusinessCategory")

  @@index([isActive, sortOrder])
}

model UserTenant {
  id            String    @id @default(cuid())
  userId        String
  tenantId      String
  role          UserRole  @default(STAFF)
  isSystemOwner Boolean   @default(false)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  user          User      @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model User {
  id                 String             @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid        String             @unique
  email              String?
  fullName           String?
  avatar             String?
  role               UserRole
  tenantId           String?
  permissions        Json?
  createdAt          DateTime           @default(now())
  createdBy          String?
  updatedAt          DateTime           @updatedAt
  updatedBy          String?
  deletedAt          DateTime?
  deletedBy          String?
  tokenVersion       Int                @default(0)
  phone              String?
  fcmToken           String?
  welcomeEmailSent   Boolean            @default(false)
  marketingConsent   Boolean            @default(false)
  privacyAcceptedAt  DateTime?
  adminUser          AdminUser?
  requestedApprovals ApprovalRequest[]  @relation("RequestedApprovals")
  resolvedApprovals  ApprovalRequest[]  @relation("ResolvedApprovals")
  emailLogs          EmailLog[]
  platformAuditLogs  PlatformAuditLog[]
  refreshTokens      RefreshToken[]
  tenant             Tenant?            @relation(fields: [tenantId], references: [id])
  userTenants        UserTenant[]
  ledgerPayments     LedgerPayment[]
  auditLogs          AuditLog[]
  assignedFollowUps  CustomerFollowUp[]
  customerNotes      CustomerNote[]
  assignedJobs       JobCard[]          @relation("JobCardAssignment")
  notificationLogs   NotificationLog[]
  shopStaffs         ShopStaff[]
  promoUsages        PromoUsage[]

  @@index([REMOVED_AUTH_PROVIDERUid])
  @@index([REMOVED_AUTH_PROVIDERUid, deletedAt])
  @@index([email])
  @@index([tenantId, deletedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Contact {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  phone           String
  normalizedPhone String
  email           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  members         Member[]
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  parties         Party[]

  @@unique([tenantId, normalizedPhone])
  @@index([tenantId])
  @@map("mb_contact")
}

model Member {
  id                  String              @id @default(uuid())
  tenantId            String
  fullName            String
  phone               String
  gender              Gender
  membershipPlanId    String
  membershipStartAt   DateTime
  membershipEndAt     DateTime
  feeAmount           Int
  paymentStatus       MemberPaymentStatus
  heightCm            Float
  weightKg            Float
  fitnessGoal         FitnessGoal
  createdAt           DateTime            @default(now())
  createdBy           String?
  updatedAt           DateTime            @updatedAt
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  paidAmount          Int                 @default(0)
  monthlyFee          Int
  paymentDueDate      DateTime
  paymentReminderSent Boolean             @default(false)
  isActive            Boolean             @default(true)
  isFrozen            Boolean             @default(false)
  frozenAt            DateTime?
  frozenDays          Int                 @default(0)
  photoUrl            String?
  welcomeMessageSent  Boolean             @default(false)
  hasCoaching         Boolean             @default(false)
  customerId          String?
  contactId           String?
  fitnessProfileId    String?
  attendances         GymAttendance[]
  gymMemberships      GymMembership[]
  classBookings       GymClassBooking[]
  contact             Contact?            @relation(fields: [contactId], references: [id])
  customer            Party?              @relation(fields: [customerId], references: [id])
  fitnessProfile      FitnessProfile?     @relation(fields: [fitnessProfileId], references: [id])
  tenant              Tenant              @relation("TenantMembers", fields: [tenantId], references: [id])
  payments            MemberPayment[]

  @@unique([id, tenantId])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([fullName])
  @@map("gp_member")
}

model Party {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  phone               String
  email               String?
  state               String?
  gstNumber           String?
  businessType        BusinessType         @default(B2C)
  partyType           PartyType            @default(CUSTOMER)
  isActive            Boolean              @default(true)
  altPhone            String?
  address             String?
  defaultPaymentTerms String?
  defaultCreditLimit  Int?
  defaultCurrency     String               @default("INR")
  tags                String[]             @default([])
  createdBy           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  deletedBy           String?
  normalizedPhone     String               @default("")
  countryCode         String               @default("IN")
  isoStateCode        String?
  pincode             String?
  distanceFromShop    Int?
  currentOutstanding  Int                  @default(0)
  mergedIntoId        String?
  contactId           String?
  customerLifecycle   CustomerLifecycle?
  emailLogs           EmailLog[]
  whatsAppLogs        WhatsAppLog[]
  members             Member[]
  ledgerCustomers     LedgerCustomer[]
  customerCreditNotes CreditNote[]         @relation("CustomerCreditNotes")
  supplierCreditNotes CreditNote[]         @relation("SupplierCreditNotes")
  alerts              CustomerAlert[]
  followUps           CustomerFollowUp[]
  customerNotes       CustomerNote[]
  reminders           CustomerReminder[]
  invoices            Invoice[]
  jobCards            JobCard[]
  loyaltyAdjustments  LoyaltyAdjustment[]
  loyaltyTransactions LoyaltyTransaction[]
  contact             Contact?             @relation(fields: [contactId], references: [id])
  mergedInto          Party?               @relation("PartyMerge", fields: [mergedIntoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mergesFrom          Party[]              @relation("PartyMerge")
  tenant              Tenant               @relation("TenantParties", fields: [tenantId], references: [id])
  paymentVouchers     PaymentVoucher[]
  purchases           Purchase[]           @relation("PartyToPurchases")
  purchaseOrders      PurchaseOrder[]
  quotations          Quotation[]
  receipts            Receipt[]
  supplierPayments    SupplierPayment[]
  supplierProfile     SupplierProfile?
  tradeIns            TradeIn[]
  installmentPlans    InstallmentPlan[]

  @@unique([tenantId, phone])
  @@unique([tenantId, normalizedPhone])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([name])
  @@map("mb_party")
}

model LoyaltyAdjustment {
  id           String   @id @default(cuid())
  tenantId     String
  partyId      String
  beforePoints Int
  afterPoints  Int
  delta        Int
  reason       String
  adjustedBy   String
  createdAt    DateTime @default(now())
  party        Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([partyId])
  @@index([createdAt])
  @@map("mb_loyalty_adjustment")
}

model SupplierProfile {
  id                String  @id @default(cuid())
  partyId           String  @unique
  category          String?
  riskFlag          Boolean @default(false)
  rating            Float   @default(0.0)
  paymentDueDays    Int     @default(30)
  creditLimit       Int?
  preferredCurrency String  @default("INR")
  party             Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@map("mb_supplier_profile")
}

model CustomerFollowUp {
  id               String         @id @default(cuid())
  tenantId         String
  customerId       String
  shopId           String?
  type             FollowUpType
  note             String?
  followUpAt       DateTime
  status           FollowUpStatus @default(PENDING)
  assignedToUserId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sourceJobId      String?
  sourceQuotationId String?
  purpose          String
  assignedToUser   User?          @relation(fields: [assignedToUserId], references: [id])
  customer         Party          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop             Shop?          @relation(fields: [shopId], references: [id])
  sourceQuotation   Quotation?      @relation(fields: [sourceQuotationId], references: [id])
  tenant           Tenant         @relation("TenantCustomerFollowUps", fields: [tenantId], references: [id])


  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([customerId])
  @@index([shopId])
  @@index([assignedToUserId])
  @@index([followUpAt])
  @@index([status])
  @@index([sourceJobId])
  @@index([tenantId, assignedToUserId, status, followUpAt])
  @@map("mb_customer_follow_up")
}

model CustomerReminder {
  id            String              @id @default(cuid())
  tenantId      String
  customerId    String
  triggerType   ReminderTriggerType
  triggerValue  String
  channel       ReminderChannel
  templateKey   String
  status        ReminderStatus      @default(SCHEDULED)
  scheduledAt   DateTime?
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  customer      Party               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant        Tenant              @relation("TenantCustomerReminders", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([status, channel, scheduledAt])
  @@index([tenantId, status, scheduledAt])
  @@map("mb_customer_reminder")
}

model CustomerNote {
  id         String    @id @default(cuid())
  tenantId   String
  customerId String
  authorId   String
  content    String
  deletedAt  DateTime?
  deletedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  author     User      @relation(fields: [authorId], references: [id])
  customer   Party     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation("TenantCustomerNotes", fields: [tenantId], references: [id])

  @@index([tenantId, customerId])
  @@index([tenantId])
  @@map("mb_customer_note")
}

model LoyaltyConfig {
  id                    String   @id @default(cuid())
  tenantId              String
  shopId                String?  @unique
  isEnabled             Boolean  @default(false)
  earnAmountPerPoint    Int      @default(10000)
  pointsPerEarnUnit     Int      @default(1)
  pointValueInRupees    Float    @default(1.0)
  maxRedeemPercent      Int      @default(50)
  allowOnRepairs        Boolean  @default(true)
  allowOnAccessories    Boolean  @default(true)
  allowOnServices       Boolean  @default(false)
  expiryDays            Int?
  allowManualAdjustment Boolean  @default(false)
  minInvoiceForEarn     Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  shop                  Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([shopId])
  @@map("mb_loyalty_config")
}

model LoyaltyTransaction {
  id          String                 @id @default(cuid())
  tenantId    String
  shopId      String?
  customerId  String
  points      Int
  type        LoyaltyTransactionType
  source      LoyaltySource
  invoiceId   String?
  reversalOf  String?
  referenceId String?
  note        String?
  createdBy   String?
  createdAt   DateTime               @default(now())
  customer    Party                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shop        Shop?                  @relation(fields: [shopId], references: [id])
  tenant      Tenant                 @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([shopId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([reversalOf])
  @@index([referenceId])
  @@index([createdAt])
  @@map("mb_loyalty_transaction")
}

model CustomerAlert {
  id         String        @id @default(cuid())
  tenantId   String
  customerId String
  severity   AlertSeverity
  message    String
  source     AlertSource
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  customer   Party         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant     Tenant        @relation("TenantCustomerAlerts", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([severity])
  @@index([resolved])
  @@index([createdAt])
  @@map("mb_customer_alert")
}

model LedgerCustomer {
  id         String          @id @default(cuid())
  tenantId   String
  customerId String?
  name       String
  phone      String
  address    String?
  email      String?
  notes      String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  ledgers    LedgerAccount[]
  customer   Party?          @relation(fields: [customerId], references: [id])
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  payments   LedgerPayment[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([customerId])
  @@map("lg_ledger_customer")
}

model LedgerAccount {
  id                String                @id @default(cuid())
  tenantId          String
  customerId        String
  principalAmount   Int
  interestRate      Int                   @default(0)
  interestRateType  String                @default("RUPEES")
  interestAmount    Int                   @default(0)
  expectedTotal     Int
  installmentType   LedgerInstallmentType
  installmentAmount Int
  totalPeriods      Int
  startDate         DateTime
  status            LedgerStatus          @default(ACTIVE)
  createdAt         DateTime              @default(now())
  customer          LedgerCustomer        @relation(fields: [customerId], references: [id])
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  collections       LedgerCollection[]
  payments          LedgerPayment[]

  // Indian Lending Enhancements
  skipSundays         Boolean       @default(false)
  processingFee       Int           @default(0)
  gracePeriodDays     Int           @default(0)
  
  // Penalty Config
  penaltyType         String        @default("NONE") // NONE, FIXED, DAILY_RUPEES, DAILY_PERCENTAGE
  penaltyValue        Int           @default(0)
  
  // Field Agent Config
  agentCommissionRate Float         @default(0.0) // Percentage of collection
  
  // Guarantor / Witness Info
  guarantorName       String?
  guarantorPhone      String?
  guarantorAddress    String?
  
  // Documentation (Safe Image Upload)
  documentUrl         String?       @map("kyc_document_url")
  
  metadata            Json?         @default("{}")

  @@index([tenantId])
  @@index([customerId])
  @@map("lg_ledger_account")
}

model LedgerCollection {
  id               String          @id @default(cuid())
  tenantId         String
  ledgerId         String
  periodNo         Int
  dueDate          DateTime
  amount           Int
  paidAmount       Int             @default(0)
  paid             Boolean         @default(false)
  paidAt           DateTime?
  isInterestOnly   Boolean         @default(false)
  collectionNote   String?
  createdAt        DateTime        @default(now())
  ledger     LedgerAccount   @relation(fields: [ledgerId], references: [id])
  payments   LedgerPayment[]

  @@index([tenantId])
  @@index([ledgerId])
  @@map("lg_ledger_collection")
}

model LedgerPayment {
  id              String              @id @default(cuid())
  tenantId        String
  ledgerId        String
  customerId      String
  collectionId    String?
  collectedBy     String
  amount          Int
  method          LedgerPaymentMethod
  paymentType     String              @default("FULL")
  note            String?
  collectedAt     DateTime            @default(now())
  createdAt       DateTime            @default(now())

  // Collection Intelligence
  agentCommission Int                 @default(0) // Calculated at payment time
  penaltyPaid     Int                 @default(0) // Amount of payment applied to penalty
  collectedByUser User                @relation(fields: [collectedBy], references: [id])
  collection      LedgerCollection?   @relation(fields: [collectionId], references: [id])
  customer        LedgerCustomer      @relation(fields: [customerId], references: [id])
  ledger          LedgerAccount       @relation(fields: [ledgerId], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([ledgerId])
  @@index([customerId])
  @@index([collectionId])
  @@index([collectedBy])
  @@map("lg_ledger_payment")
}

model StaffInvite {
  id          String            @id @default(cuid())
  email       String
  tenantId    String
  createdAt   DateTime          @default(now())
  role        UserRole          @default(STAFF)
  roleId      String?
  name        String?
  phone       String?
  shopIds     String[]          @default([])
  deletedAt   DateTime?
  deletedBy   String?
  expiresAt   DateTime?
  inviteToken String?           @unique @default(cuid())
  status      StaffInviteStatus @default(PENDING)
  updatedAt   DateTime?         @updatedAt
  dynamicRole Role?             @relation(fields: [roleId], references: [id])
  tenant      Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email, status], name: "invite_composite_key")
  @@index([email, status, deletedAt])
  @@index([email])
  @@index([tenantId])
  @@index([status])
