// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String              @id @default(cuid())
  name         String
  code         String              @unique
  subscription TenantSubscription?
  createdAt    DateTime            @default(now())

  users     User[]
  members   Member[]
  payments  Payment[]
  auditLogs AuditLog[]
}

model User {
  id          String     @id @default(uuid())
  REMOVED_AUTH_PROVIDERUid String     @unique
  email       String?
  fullName    String? // store REMOVED_AUTH_PROVIDER/display name
  avatar      String?
  role        String?    @default("member")
  tenantId    String? // optional FK to Tenant
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])
  permissions Json? // JSON field to store user permissions
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
}

model Member {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  gymMemberships GymMembership[]
  gymAttendances GymAttendance[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model StaffInvite {
  id        String   @id @default(uuid())
  email     String
  tenantId  String
  createdAt DateTime @default(now())
}

model Plan {
  id           String  @id @default(cuid())
  name         String
  price        Int?
  durationDays Int
  features     Json?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id String @id @default(cuid())

  tenantId String
  planId   String

  status    SubscriptionStatus
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  plan      Plan     @relation(fields: [planId], references: [id])

  @@unique([tenantId])
}

model Payment {
  id       String @id @default(cuid())
  tenantId String
  planName String
  amount   Int
  currency String

  REMOVED_PAYMENT_INFRAOrderId   String
  REMOVED_PAYMENT_INFRAPaymentId String
  REMOVED_PAYMENT_INFRASignature String

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model GymMembership {
  id       String @id @default(cuid())
  tenantId String
  memberId String

  startDate DateTime
  endDate   DateTime

  status MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  member Member @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

model GymAttendance {
  id       String @id @default(cuid())
  tenantId String
  memberId String

  checkInTime  DateTime
  checkOutTime DateTime?

  source AttendanceSource @default(MANUAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([tenantId])
  @@index([memberId])
}

enum AttendanceSource {
  MANUAL
  QR
  BIOMETRIC
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
}
