  grns                 GRN[]
  purchases            Purchase[]

  @@unique([shopId, poNumber])
  @@index([tenantId])
  @@index([shopId])
  @@map("mb_purchase_order")
}

model GRN {
  id                   String    @id @default(cuid())
  tenantId             String
  shopId               String
  poId                 String
  grnNumber            String
  receivedDate         DateTime  @default(now())
  status               GRNStatus @default(DRAFT)
  isVarianceOverridden Boolean   @default(false)
  overrideNote         String?
  overriddenBy         String? // UserID (OWNER only)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  po    PurchaseOrder @relation(fields: [poId], references: [id])
  items GRNItem[]

  @@unique([shopId, grnNumber])
  @@index([tenantId])
  @@index([shopId])
  @@index([poId])
  @@map("mb_grn")
}

model GRNItem {
  id               String  @id @default(cuid())
  grnId            String
  poItemId         String
  shopProductId    String
  receivedQuantity Int
  confirmedPrice   Int? // Price at time of receipt (for WAC)
  uom              String? @default("pcs")

  grn     GRN               @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poItem  PurchaseOrderItem @relation(fields: [poItemId], references: [id])
  product ShopProduct       @relation(fields: [shopProductId], references: [id])

  @@index([grnId])
  @@index([poItemId])
  @@map("mb_grn_item")
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  poId             String
  globalProductId  String?
  description      String
  quantity         Int
  estimatedPrice   Int?
  receivedQuantity Int           @default(0)
  uom              String?       @default("pcs")
  po               PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  grnItems         GRNItem[]

  @@index([poId])
  @@map("mb_purchase_order_item")
}

